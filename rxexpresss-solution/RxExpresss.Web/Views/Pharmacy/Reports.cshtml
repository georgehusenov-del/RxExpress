@{ Layout = "_SidebarLayout"; }
<style>
.filter-bar{display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end}
.filter-bar .form-group{margin:0;min-width:160px}
.preset-btns{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
.preset-btns button{padding:4px 10px;font-size:12px}
.tabs{display:flex;gap:4px;border-bottom:1px solid var(--border);margin-bottom:16px;overflow-x:auto}
.tabs button{background:none;border:none;padding:10px 16px;cursor:pointer;border-bottom:2px solid transparent;color:var(--gray);font-weight:500;white-space:nowrap}
.tabs button.active{color:var(--primary);border-color:var(--primary)}
.stat-card{padding:14px 16px;background:#fff;border-radius:8px;border:1px solid var(--border);flex:1;min-width:160px}
.stat-card .stat-label{font-size:12px;color:var(--gray);text-transform:uppercase;letter-spacing:.3px}
.stat-card .stat-value{font-size:22px;font-weight:700;margin-top:4px}
</style>

<div class="card mb-3">
    <div class="card-body">
        <div class="filter-bar">
            <div class="form-group">
                <label>From Date</label>
                <input type="date" class="form-control" id="r-from" data-testid="report-from-date"/>
            </div>
            <div class="form-group">
                <label>To Date</label>
                <input type="date" class="form-control" id="r-to" data-testid="report-to-date"/>
            </div>
            <div class="form-group">
                <label>Driver</label>
                <select class="form-control" id="r-driver" data-testid="report-driver-filter">
                    <option value="">All Drivers</option>
                </select>
            </div>
            <div class="form-group">
                <label>Status</label>
                <select class="form-control" id="r-status" data-testid="report-status-filter">
                    <option value="">All</option>
                    <option value="new">New</option>
                    <option value="assigned">Assigned</option>
                    <option value="picked_up">Picked Up</option>
                    <option value="in_transit">In Transit</option>
                    <option value="out_for_delivery">Out for Delivery</option>
                    <option value="delivered">Delivered</option>
                    <option value="failed">Failed</option>
                    <option value="cancelled">Cancelled</option>
                </select>
            </div>
            <button class="btn btn-primary" onclick="runReports()" data-testid="report-apply-btn">Apply</button>
            <button class="btn btn-outline" onclick="exportCsv()" data-testid="report-export-btn">Export CSV</button>
        </div>
        <div class="preset-btns">
            <button class="btn btn-outline btn-sm" onclick="preset('today')">Today</button>
            <button class="btn btn-outline btn-sm" onclick="preset('7d')">Last 7 days</button>
            <button class="btn btn-outline btn-sm" onclick="preset('30d')">Last 30 days</button>
            <button class="btn btn-outline btn-sm" onclick="preset('this_month')">This Month</button>
            <button class="btn btn-outline btn-sm" onclick="preset('last_month')">Last Month</button>
            <button class="btn btn-outline btn-sm" onclick="preset('this_year')">This Year</button>
        </div>
    </div>
</div>

<div id="summary-tiles" class="mb-3"></div>

<div class="tabs">
    <button class="tab-btn active" data-tab="monthly" onclick="switchTab('monthly')">Monthly Breakdown</button>
    <button class="tab-btn" data-tab="driver" onclick="switchTab('driver')">By Driver</button>
    <button class="tab-btn" data-tab="status" onclick="switchTab('status')">Status Breakdown</button>
</div>

<div id="tab-monthly" class="tab-panel">
    <div class="card"><div class="card-body table-wrap"><div id="monthly-mount"><p class="text-gray">Loading...</p></div></div></div>
</div>
<div id="tab-driver" class="tab-panel" style="display:none">
    <div class="card"><div class="card-body table-wrap"><div id="driver-mount"><p class="text-gray">Loading...</p></div></div></div>
</div>
<div id="tab-status" class="tab-panel" style="display:none">
    <div class="card"><div class="card-body"><div id="status-mount"></div></div></div>
</div>

@section Scripts {
<script src="~/js/reports.js"></script>
<script>
if(!ApiService.requireAuth('Pharmacy'))throw'';

function getFilters(){
    return {
        from: document.getElementById('r-from').value,
        to: document.getElementById('r-to').value,
        driverId: document.getElementById('r-driver').value || null,
        status: document.getElementById('r-status').value || null
    };
}

async function loadDriverDropdown(){
    const f = { from: document.getElementById('r-from').value, to: document.getElementById('r-to').value };
    try{
        const d = await ApiService.get('/pharmacies/reports/drivers-list?' + ReportsUI.buildQuery(f));
        const sel = document.getElementById('r-driver');
        const current = sel.value;
        sel.innerHTML = '<option value="">All Drivers</option>' +
            (d.drivers || []).map(x => `<option value="${x.driverId}">${x.driverName || 'Driver #' + x.driverId}</option>`).join('');
        sel.value = current;
    }catch(e){console.error('driver list failed',e);}
}

function preset(p){
    ReportsUI.applyPreset(p);
    runReports();
}

function switchTab(name){
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === name));
    document.querySelectorAll('.tab-panel').forEach(p => p.style.display = 'none');
    document.getElementById('tab-' + name).style.display = 'block';
}

async function runReports(){
    const f = getFilters();
    const qs = ReportsUI.buildQuery(f);
    try{
        await loadDriverDropdown();
        const [summary, monthly, byDriver] = await Promise.all([
            ApiService.get('/pharmacies/reports/summary?' + qs),
            ApiService.get('/pharmacies/reports/monthly?' + qs),
            ApiService.get('/pharmacies/reports/by-driver?' + ReportsUI.buildQuery({from:f.from,to:f.to,status:f.status}))
        ]);
        ReportsUI.renderSummaryTiles(summary, 'summary-tiles');
        ReportsUI.renderMonthly(monthly.months || [], 'monthly-mount');
        renderDriverTable(byDriver.drivers || []);
        ReportsUI.renderStatusBreakdown(summary, 'status-mount');
    }catch(err){
        showAlert('alert-area','danger','Failed to load reports: '+err.message);
    }
}

function renderDriverTable(rows){
    if(!rows.length){ document.getElementById('driver-mount').innerHTML='<p class="text-gray text-center">No driver data.</p>'; return; }
    document.getElementById('driver-mount').innerHTML = `
        <table><thead><tr>
            <th>Driver</th><th>Total</th><th>Delivered</th><th>Failed</th><th>Success Rate</th>
        </tr></thead><tbody>
        ${rows.map(d => `<tr>
            <td><strong>${d.driverName}</strong></td>
            <td>${d.total}</td>
            <td style="color:#22c55e">${d.delivered}</td>
            <td style="color:#ef4444">${d.failed}</td>
            <td>${d.successRate}%</td>
        </tr>`).join('')}
        </tbody></table>`;
}

async function exportCsv(){
    const f = getFilters();
    const qs = ReportsUI.buildQuery(f);
    try{
        const token = ApiService.getToken();
        const res = await fetch(`${API_BASE_URL}/pharmacies/reports/export?${qs}`, {
            headers: { 'Authorization': 'Bearer ' + token }
        });
        if(!res.ok){ throw new Error('Export failed: '+res.status); }
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `pharmacy-report-${f.from}-to-${f.to}.csv`;
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
    }catch(err){ showAlert('alert-area','danger',err.message); }
}

(async () => {
    const { from, to } = ReportsUI.defaultRange();
    document.getElementById('r-from').value = from;
    document.getElementById('r-to').value = to;
    await runReports();
})();
</script>
}
