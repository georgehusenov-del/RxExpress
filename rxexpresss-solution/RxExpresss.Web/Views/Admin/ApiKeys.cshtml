@{ Layout = "_SidebarLayout"; }
@section TopbarRight { 
    <div class="d-flex gap-2">
        <select class="form-control" style="width:200px" id="pharmacyFilter" onchange="load()">
            <option value="">All Pharmacies</option>
        </select>
        <button class="btn btn-outline" onclick="load()" title="Refresh" data-testid="refresh-btn">🔄 Refresh</button>
        <button class="btn btn-primary" onclick="openCreateModal()" data-testid="create-api-key-btn">+ Create API Key</button>
    </div>
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card" style="background: linear-gradient(135deg, var(--primary), var(--primary-dark));">
            <div class="card-body text-center">
                <h3 id="totalKeys" style="font-size: 2rem; margin: 0;">0</h3>
                <p style="margin: 0; opacity: 0.9;">Total API Keys</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="background: linear-gradient(135deg, #22c55e, #16a34a);">
            <div class="card-body text-center">
                <h3 id="activeKeys" style="font-size: 2rem; margin: 0;">0</h3>
                <p style="margin: 0; opacity: 0.9;">Active Keys</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <div class="card-body text-center">
                <h3 id="totalRequests" style="font-size: 2rem; margin: 0;">0</h3>
                <p style="margin: 0; opacity: 0.9;">Total API Requests</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Pharmacy</th>
                    <th>Key Name</th>
                    <th>API Key</th>
                    <th>Status</th>
                    <th>Requests</th>
                    <th>Last Used</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tbl" data-testid="api-keys-table"></tbody>
        </table>
    </div>
</div>

<!-- Create API Key Modal -->
<div class="modal-overlay" id="create-modal">
    <div class="modal">
        <div class="modal-header">
            <h3>Create API Key</h3>
            <button class="close-btn" onclick="closeCreateModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Pharmacy</label>
                <select class="form-control" id="m-pharmacy" data-testid="pharmacy-select">
                    <option value="">Select Pharmacy</option>
                </select>
            </div>
            <div class="form-group">
                <label>Key Name</label>
                <input class="form-control" id="m-name" placeholder="e.g., Production Key, Test Key" data-testid="key-name-input"/>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeCreateModal()">Cancel</button>
            <button class="btn btn-primary" onclick="createKey()" data-testid="create-key-submit">Create Key</button>
        </div>
    </div>
</div>

<!-- Show Credentials Modal (shown only once after creation) -->
<div class="modal-overlay" id="credentials-modal">
    <div class="modal" style="max-width: 600px;">
        <div class="modal-header" style="background: linear-gradient(135deg, #22c55e, #16a34a);">
            <h3 style="color: white;">API Key Created Successfully!</h3>
            <button class="close-btn" onclick="closeCredentialsModal()" style="color: white;">&times;</button>
        </div>
        <div class="modal-body">
            <div class="alert" style="background: #fef3c7; border-left: 4px solid #f59e0b; padding: 1rem; margin-bottom: 1rem;">
                <strong>⚠️ Important:</strong> Save these credentials now! The secret will never be shown again.
            </div>
            
            <div class="form-group">
                <label>Pharmacy</label>
                <input class="form-control" id="cred-pharmacy" readonly style="background: var(--bg-light);"/>
            </div>
            
            <div class="form-group">
                <label>API Key</label>
                <div style="display: flex; gap: 8px;">
                    <input class="form-control" id="cred-key" readonly style="background: var(--bg-light); font-family: monospace;"/>
                    <button class="btn btn-outline" onclick="copyToClipboard('cred-key')" title="Copy">📋</button>
                </div>
            </div>
            
            <div class="form-group">
                <label>API Secret</label>
                <div style="display: flex; gap: 8px;">
                    <input class="form-control" id="cred-secret" readonly style="background: var(--bg-light); font-family: monospace;"/>
                    <button class="btn btn-outline" onclick="copyToClipboard('cred-secret')" title="Copy">📋</button>
                </div>
            </div>
            
            <div style="background: var(--bg-dark); padding: 1rem; border-radius: 8px; margin-top: 1rem;">
                <p style="margin: 0 0 0.5rem 0; font-weight: 600;">Usage Example:</p>
                <pre style="margin: 0; font-size: 0.85rem; overflow-x: auto;"><code>curl -X POST https://backend.rxexpresss.com/api/v1/orders \
  -H "X-API-Key: <span id="example-key"></span>" \
  -H "X-API-Secret: <span id="example-secret"></span>" \
  -H "Content-Type: application/json" \
  -d '{"patientName": "John Doe", ...}'</code></pre>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-primary" onclick="closeCredentialsModal()">I've Saved These Credentials</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
if(!ApiService.requireAuth('Admin')) throw '';

let pharmacies = [];

async function loadPharmacies() {
    const data = await ApiService.get('/admin/pharmacies');
    pharmacies = data.pharmacies || [];
    
    const filterSelect = document.getElementById('pharmacyFilter');
    const modalSelect = document.getElementById('m-pharmacy');
    
    pharmacies.forEach(p => {
        filterSelect.innerHTML += `<option value="${p.id}">${p.name}</option>`;
        modalSelect.innerHTML += `<option value="${p.id}">${p.name}</option>`;
    });
}

async function load() {
    const pharmacyId = document.getElementById('pharmacyFilter').value;
    const url = pharmacyId ? `/admin/api-keys?pharmacyId=${pharmacyId}` : '/admin/api-keys';
    
    const data = await ApiService.get(url);
    const keys = data.apiKeys || [];
    
    // Update stats
    document.getElementById('totalKeys').textContent = keys.length;
    document.getElementById('activeKeys').textContent = keys.filter(k => k.isActive).length;
    document.getElementById('totalRequests').textContent = keys.reduce((sum, k) => sum + k.requestCount, 0).toLocaleString();
    
    const tbody = document.getElementById('tbl');
    if (keys.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-gray">No API keys found. Create one to enable pharmacy integrations.</td></tr>';
        return;
    }
    
    tbody.innerHTML = keys.map(k => `<tr data-testid="api-key-row-${k.id}">
        <td><strong>${k.pharmacyName}</strong></td>
        <td>${k.name}</td>
        <td><code style="background: var(--bg-dark); padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">${k.key}</code></td>
        <td>${k.isActive 
            ? '<span class="badge" style="background: #22c55e;">Active</span>' 
            : '<span class="badge" style="background: #ef4444;">Inactive</span>'}</td>
        <td>${k.requestCount.toLocaleString()}</td>
        <td>${k.lastUsedAt ? formatDate(k.lastUsedAt) : '<span class="text-gray">Never</span>'}</td>
        <td>${formatDate(k.createdAt)}</td>
        <td>
            <button class="btn btn-sm ${k.isActive ? 'btn-warning' : 'btn-success'}" onclick="toggleKey(${k.id}, ${k.isActive})" data-testid="toggle-key-${k.id}">
                ${k.isActive ? 'Disable' : 'Enable'}
            </button>
            <button class="btn btn-sm btn-danger" onclick="deleteKey(${k.id})" data-testid="delete-key-${k.id}">Delete</button>
        </td>
    </tr>`).join('');
}

function openCreateModal() {
    document.getElementById('m-pharmacy').value = '';
    document.getElementById('m-name').value = '';
    document.getElementById('create-modal').classList.add('active');
}

function closeCreateModal() {
    document.getElementById('create-modal').classList.remove('active');
}

async function createKey() {
    const pharmacyId = document.getElementById('m-pharmacy').value;
    const name = document.getElementById('m-name').value.trim();
    
    if (!pharmacyId) {
        toastr.error('Please select a pharmacy');
        return;
    }
    
    try {
        const result = await ApiService.post('/admin/api-keys', {
            pharmacyId: parseInt(pharmacyId),
            name: name || 'Default API Key'
        });
        
        closeCreateModal();
        
        // Show credentials modal
        document.getElementById('cred-pharmacy').value = result.pharmacyName;
        document.getElementById('cred-key').value = result.key;
        document.getElementById('cred-secret').value = result.secret;
        document.getElementById('example-key').textContent = result.key;
        document.getElementById('example-secret').textContent = result.secret.substring(0, 8) + '...';
        document.getElementById('credentials-modal').classList.add('active');
        
        toastr.success('API key created successfully!');
        await load(); // Await the load
    } catch (err) {
        toastr.error(err.message || 'Failed to create API key');
    }
}

function closeCredentialsModal() {
    document.getElementById('credentials-modal').classList.remove('active');
}

function copyToClipboard(elementId) {
    const input = document.getElementById(elementId);
    input.select();
    document.execCommand('copy');
    toastr.success('Copied to clipboard!');
}

async function toggleKey(id, currentStatus) {
    if (!confirm(`Are you sure you want to ${currentStatus ? 'disable' : 'enable'} this API key?`)) return;
    
    try {
        await ApiService.put(`/admin/api-keys/${id}/toggle`);
        toastr.success(`API key ${currentStatus ? 'disabled' : 'enabled'}`);
        await load(); // Await the load
    } catch (err) {
        toastr.error(err.message || 'Failed to toggle API key');
    }
}

async function deleteKey(id) {
    if (!confirm('Are you sure you want to delete this API key? This action cannot be undone and will break any integrations using this key.')) return;
    
    try {
        await ApiService.delete(`/admin/api-keys/${id}`);
        toastr.success('API key deleted');
        await load(); // Await the load
    } catch (err) {
        toastr.error(err.message || 'Failed to delete API key');
    }
}

function formatDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-US', { 
        month: 'short', 
        day: 'numeric', 
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    });
}

// Initialize
loadPharmacies();
load();
</script>
}
