@{ Layout = "_SidebarLayout"; }
@section TopbarRight {
    <div class="d-flex gap-2 items-center">
        <span class="text-gray" id="last-refresh" data-testid="last-refresh">--</span>
        <button class="btn btn-sm btn-outline" onclick="loadTracking()" data-testid="refresh-tracking-btn">Refresh</button>
        <label class="d-flex items-center gap-1" style="cursor:pointer">
            <input type="checkbox" id="auto-refresh" checked onchange="toggleAutoRefresh()" data-testid="auto-refresh-toggle"/>
            <span style="font-size:13px">Auto (10s)</span>
        </label>
    </div>
}

<div class="tracking-layout" data-testid="tracking-layout">
    <!-- Map Container -->
    <div class="map-container" data-testid="map-container">
        <div id="map" style="width:100%;height:100%"></div>
    </div>
    
    <!-- Driver List Sidebar -->
    <div class="driver-panel" data-testid="driver-panel">
        <div class="panel-header">
            <strong>Drivers</strong>
            <span class="badge badge-info" id="driver-count" data-testid="driver-count">0</span>
        </div>
        <div class="driver-filter">
            <button class="filter-btn active" data-filter="all" onclick="filterDrivers('all')" data-testid="filter-all">All</button>
            <button class="filter-btn" data-filter="online" onclick="filterDrivers('online')" data-testid="filter-online">Online</button>
            <button class="filter-btn" data-filter="on_route" onclick="filterDrivers('on_route')" data-testid="filter-on-route">On Route</button>
        </div>
        <div id="driver-list" class="driver-list" data-testid="driver-list"></div>
    </div>
</div>

@section Scripts {
<!-- Google Maps JS API (dummy key — replace with real key for production) -->
<script>
// Google Maps initialization
let map, markers = {}, trails = {}, infoWindows = {}, officeMarkers = [];
let trackingData = { drivers: [], offices: [] };
let autoRefreshTimer = null;
let activeFilter = 'all';
let selectedDriverId = null;

// Map config
const MAP_CENTER = { lat: 40.7128, lng: -74.0060 }; // NYC default
const GOOGLE_MAPS_KEY = '@(ViewData["GoogleMapsKey"] ?? "")';

function initMap() {
    map = new google.maps.Map(document.getElementById('map'), {
        center: MAP_CENTER,
        zoom: 11,
        mapTypeControl: true,
        streetViewControl: false,
        styles: [
            { featureType: 'poi', stylers: [{ visibility: 'off' }] },
            { featureType: 'transit', stylers: [{ visibility: 'simplified' }] }
        ]
    });
    
    loadTracking();
    startAutoRefresh();
}

async function loadTracking() {
    try {
        const data = await ApiService.get('/admin/tracking/drivers');
        trackingData = data;
        updateMap(data.drivers, data.offices);
        updateDriverList(data.drivers);
        document.getElementById('last-refresh').textContent = 'Updated ' + new Date().toLocaleTimeString();
    } catch(e) {
        console.error('Tracking load failed:', e);
    }
}

function updateMap(drivers, offices) {
    // Clear old office markers
    officeMarkers.forEach(m => m.setMap(null));
    officeMarkers = [];
    
    // Add office markers
    offices.forEach(o => {
        if (o.latitude && o.longitude) {
            const marker = new google.maps.Marker({
                position: { lat: o.latitude, lng: o.longitude },
                map: map,
                icon: {
                    path: google.maps.SymbolPath.CIRCLE,
                    scale: 10,
                    fillColor: '#1e40af',
                    fillOpacity: 0.9,
                    strokeColor: '#fff',
                    strokeWeight: 2
                },
                title: o.name,
                zIndex: 1
            });
            
            const infoWindow = new google.maps.InfoWindow({
                content: `<div style="padding:4px"><strong>${o.name}</strong><br/><small>${o.address}, ${o.city}</small><br/><small>Radius: ${o.radiusMeters}m</small></div>`
            });
            marker.addListener('click', () => infoWindow.open(map, marker));
            
            // Draw radius circle
            new google.maps.Circle({
                map: map,
                center: { lat: o.latitude, lng: o.longitude },
                radius: o.radiusMeters,
                fillColor: '#1e40af',
                fillOpacity: 0.08,
                strokeColor: '#1e40af',
                strokeWeight: 1,
                strokeOpacity: 0.3
            });
            
            officeMarkers.push(marker);
        }
    });
    
    // Update driver markers
    const activeDriverIds = new Set();
    
    drivers.forEach(d => {
        if (!d.latitude || !d.longitude) return;
        activeDriverIds.add(d.id);
        
        const pos = { lat: d.latitude, lng: d.longitude };
        const statusColor = getStatusColor(d.status, d.isOnline);
        const rotation = d.heading || 0;
        
        if (markers[d.id]) {
            // Update existing marker position (smooth animation)
            markers[d.id].setPosition(pos);
            markers[d.id].setIcon(getDriverIcon(statusColor, rotation));
        } else {
            // Create new marker
            markers[d.id] = new google.maps.Marker({
                position: pos,
                map: map,
                icon: getDriverIcon(statusColor, rotation),
                title: d.name,
                zIndex: 10
            });
            
            markers[d.id].addListener('click', () => {
                selectDriver(d.id);
            });
        }
        
        // Update info window content
        if (!infoWindows[d.id]) {
            infoWindows[d.id] = new google.maps.InfoWindow();
        }
        infoWindows[d.id].setContent(getDriverInfoHtml(d));
    });
    
    // Remove markers for drivers no longer reporting
    Object.keys(markers).forEach(id => {
        if (!activeDriverIds.has(parseInt(id))) {
            markers[id].setMap(null);
            delete markers[id];
        }
    });
}

function getDriverIcon(color, rotation) {
    return {
        path: 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z',
        fillColor: color,
        fillOpacity: 1,
        strokeColor: '#fff',
        strokeWeight: 1.5,
        scale: 1.8,
        anchor: new google.maps.Point(12, 22),
        rotation: rotation
    };
}

function getStatusColor(status, isOnline) {
    if (!isOnline) return '#94a3b8'; // gray - offline
    switch(status) {
        case 'available': return '#22c55e'; // green
        case 'on_route': return '#3b82f6'; // blue
        case 'on_break': return '#f59e0b'; // amber
        default: return '#94a3b8'; // gray
    }
}

function getDriverInfoHtml(d) {
    const speedMph = d.speed ? (d.speed * 2.237).toFixed(1) : '0';
    const ago = d.lastUpdate ? getTimeAgo(new Date(d.lastUpdate)) : 'Never';
    return `<div style="padding:6px;min-width:180px">
        <strong style="font-size:14px">${d.name}</strong>
        <div style="margin:6px 0;display:flex;gap:6px;flex-wrap:wrap">
            <span style="background:${getStatusColor(d.status, d.isOnline)};color:#fff;padding:2px 8px;border-radius:10px;font-size:11px">${d.status}</span>
            ${d.activeDeliveries > 0 ? `<span style="background:#8b5cf6;color:#fff;padding:2px 8px;border-radius:10px;font-size:11px">${d.activeDeliveries} deliveries</span>` : ''}
        </div>
        <div style="font-size:12px;color:#666">
            <div>${d.vehicleType} ${d.vehicleNumber ? '• ' + d.vehicleNumber : ''}</div>
            <div>Speed: ${speedMph} mph</div>
            <div>Last update: ${ago}</div>
        </div>
        <button onclick="showTrail(${d.id})" style="margin-top:6px;padding:4px 10px;background:#3b82f6;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px">Show Trail</button>
    </div>`;
}

function getTimeAgo(date) {
    const seconds = Math.floor((new Date() - date) / 1000);
    if (seconds < 60) return seconds + 's ago';
    if (seconds < 3600) return Math.floor(seconds/60) + 'm ago';
    return Math.floor(seconds/3600) + 'h ago';
}

function updateDriverList(drivers) {
    const filtered = drivers.filter(d => {
        if (activeFilter === 'online') return d.isOnline;
        if (activeFilter === 'on_route') return d.status === 'on_route';
        return true;
    });
    
    document.getElementById('driver-count').textContent = filtered.length;
    
    document.getElementById('driver-list').innerHTML = filtered.length ? filtered.map(d => {
        const statusColor = getStatusColor(d.status, d.isOnline);
        const ago = d.lastUpdate ? getTimeAgo(new Date(d.lastUpdate)) : 'No signal';
        const isSelected = d.id === selectedDriverId;
        
        return `<div class="driver-item ${isSelected ? 'driver-selected' : ''}" 
                     onclick="selectDriver(${d.id})" data-testid="driver-item-${d.id}">
            <div class="driver-dot" style="background:${statusColor}"></div>
            <div class="driver-details">
                <strong>${d.name}</strong>
                <div class="driver-meta">
                    <span class="driver-status" style="color:${statusColor}">${d.status}</span>
                    ${d.activeDeliveries > 0 ? `<span class="driver-deliveries">${d.activeDeliveries} deliveries</span>` : ''}
                </div>
                <small class="text-gray">${ago} ${d.latitude ? '' : '• No GPS'}</small>
            </div>
            ${d.latitude ? `<button class="btn-locate" onclick="event.stopPropagation();centerOnDriver(${d.id})" title="Center on map">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>
            </button>` : ''}
        </div>`;
    }).join('') : '<div class="empty-drivers">No drivers match filter</div>';
}

function filterDrivers(filter) {
    activeFilter = filter;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.filter === filter));
    updateDriverList(trackingData.drivers);
}

function selectDriver(driverId) {
    selectedDriverId = selectedDriverId === driverId ? null : driverId;
    updateDriverList(trackingData.drivers);
    
    if (selectedDriverId && markers[selectedDriverId]) {
        map.panTo(markers[selectedDriverId].getPosition());
        map.setZoom(15);
        infoWindows[selectedDriverId].open(map, markers[selectedDriverId]);
    }
}

function centerOnDriver(driverId) {
    if (markers[driverId]) {
        map.panTo(markers[driverId].getPosition());
        map.setZoom(16);
        infoWindows[driverId].open(map, markers[driverId]);
    }
}

async function showTrail(driverId) {
    try {
        const data = await ApiService.get(`/admin/tracking/drivers/${driverId}/trail?hours=2`);
        
        // Clear existing trail for this driver
        if (trails[driverId]) {
            trails[driverId].setMap(null);
        }
        
        if (data.trail && data.trail.length > 1) {
            const path = data.trail.map(p => ({ lat: p.latitude, lng: p.longitude }));
            trails[driverId] = new google.maps.Polyline({
                path: path,
                geodesic: true,
                strokeColor: '#3b82f6',
                strokeOpacity: 0.8,
                strokeWeight: 3,
                map: map
            });
            
            // Fit map to trail
            const bounds = new google.maps.LatLngBounds();
            path.forEach(p => bounds.extend(p));
            map.fitBounds(bounds, 50);
            
            toast(`Showing trail: ${data.count} points (last 2 hours)`, 'info');
        } else {
            toast('No trail data available for this driver', 'warning');
        }
    } catch(e) {
        toast('Failed to load trail', 'danger');
    }
}

function startAutoRefresh() {
    if (autoRefreshTimer) clearInterval(autoRefreshTimer);
    if (document.getElementById('auto-refresh').checked) {
        autoRefreshTimer = setInterval(loadTracking, 10000);
    }
}

function toggleAutoRefresh() {
    if (document.getElementById('auto-refresh').checked) {
        startAutoRefresh();
    } else {
        if (autoRefreshTimer) clearInterval(autoRefreshTimer);
    }
}

// Check auth then init
if(!ApiService.requirePermission('tracking.view'))throw'';
</script>

<!-- Load Google Maps JS API -->
<script>
(function() {
    const key = GOOGLE_MAPS_KEY;
    const isDummyKey = !key || key === '' || key === 'YOUR_GOOGLE_MAPS_API_KEY_HERE';
    
    if (isDummyKey) {
        // No valid API key — show fallback immediately
        showMapFallback();
        loadTrackingWithoutMap();
        return;
    }
    
    const script = document.createElement('script');
    script.src = `https://maps.googleapis.com/maps/api/js?key=${key}&callback=initMap`;
    script.async = true;
    script.defer = true;
    script.onerror = () => {
        showMapFallback();
        loadTrackingWithoutMap();
    };
    document.head.appendChild(script);
    
    // Fallback if Google Maps doesn't load within 5 seconds
    setTimeout(() => {
        if (typeof google === 'undefined' || !google.maps) {
            showMapFallback();
            loadTrackingWithoutMap();
        }
    }, 5000);
})();

function showMapFallback() {
    document.getElementById('map').innerHTML = `
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;background:#1e293b;color:#94a3b8;text-align:center;padding:40px">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:16px;color:#3b82f6"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <h3 style="color:#e2e8f0;margin-bottom:8px">Google Maps API Key Required</h3>
            <p>Add your Google Maps API key to <code style="background:#334155;padding:2px 6px;border-radius:4px">appsettings.json</code></p>
            <p style="margin-top:8px">Driver locations are being tracked in the sidebar panel.</p>
            <p style="margin-top:16px;font-size:12px">Get a key at <a href="https://console.cloud.google.com/" target="_blank" style="color:#3b82f6">console.cloud.google.com</a><br/>Enable: Maps JavaScript API</p>
        </div>`;
}

async function loadTrackingWithoutMap() {
    try {
        const data = await ApiService.get('/admin/tracking/drivers');
        trackingData = data;
        updateDriverList(data.drivers);
        document.getElementById('last-refresh').textContent = 'Updated ' + new Date().toLocaleTimeString();
        startAutoRefresh();
    } catch(e) {
        console.error('Tracking load failed:', e);
    }
}
</script>

<style>
.tracking-layout {
    display: flex;
    gap: 0;
    height: calc(100vh - 120px);
    margin: -16px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
}
.map-container {
    flex: 1;
    min-height: 400px;
    background: #1e293b;
}
.driver-panel {
    width: 320px;
    background: var(--card-bg);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.panel-header {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.driver-filter {
    display: flex;
    gap: 4px;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
}
.filter-btn {
    padding: 4px 12px;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 12px;
    transition: all 0.15s;
}
.filter-btn.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
}
.driver-list {
    flex: 1;
    overflow-y: auto;
}
.driver-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.15s;
}
.driver-item:hover {
    background: var(--bg-secondary);
}
.driver-selected {
    background: rgba(59, 130, 246, 0.1) !important;
    border-left: 3px solid #3b82f6;
}
.driver-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
}
.driver-details {
    flex: 1;
    min-width: 0;
}
.driver-details strong {
    display: block;
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.driver-meta {
    display: flex;
    gap: 6px;
    margin-top: 2px;
}
.driver-status {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
}
.driver-deliveries {
    font-size: 11px;
    color: #8b5cf6;
    font-weight: 500;
}
.btn-locate {
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px;
    cursor: pointer;
    color: var(--text-secondary);
    flex-shrink: 0;
}
.btn-locate:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
}
.empty-drivers {
    padding: 30px;
    text-align: center;
    color: var(--text-secondary);
    font-size: 13px;
}

@@media (max-width: 768px) {
    .tracking-layout {
        flex-direction: column-reverse;
        height: auto;
    }
    .map-container {
        height: 400px;
    }
    .driver-panel {
        width: 100%;
        max-height: 300px;
    }
}
</style>
}
