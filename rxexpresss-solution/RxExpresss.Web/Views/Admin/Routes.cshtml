@{ Layout = "_SidebarLayout"; }
@section TopbarRight { <button class="btn btn-primary" onclick="document.getElementById('create-modal').classList.add('active')">+ Create Gig</button> }

<div class="row mb-2">
    <div class="col"><div class="card"><div class="card-header">Pending Orders (Ready for Routing)</div><div class="card-body table-wrap"><table><thead><tr><th><input type="checkbox" id="select-all" onchange="toggleAll()"/></th><th>Order #</th><th>QR</th><th>Recipient</th><th>City</th><th>Type</th></tr></thead><tbody id="pending-tbl"></tbody></table></div></div></div>
</div>

<!-- Tab navigation -->
<div class="mb-2">
    <button class="btn btn-outline" id="tab-active" onclick="showTab('active')" style="margin-right:8px">Active Gigs</button>
    <button class="btn btn-outline" id="tab-completed" onclick="showTab('completed')">Completed Gigs</button>
</div>

<div class="card" id="active-section"><div class="card-header d-flex justify-between items-center"><span>Active Gigs (Route Plans)</span></div><div class="card-body" id="gigs-list"></div></div>

<div class="card" id="completed-section" style="display:none"><div class="card-header">Completed/Past Gigs</div><div class="card-body" id="completed-list"></div></div>

<!-- Create Gig Modal -->
<div class="modal-overlay" id="create-modal"><div class="modal"><div class="modal-header"><h3>Create New Gig</h3><button class="close-btn" onclick="closeM('create-modal')">&times;</button></div><div class="modal-body">
    <div class="form-group"><label>Title</label><input class="form-control" id="g-title" placeholder="e.g. Morning Route - Queens"/></div>
    <div class="form-group"><label>Date</label><input type="date" class="form-control" id="g-date"/></div>
    <div class="form-group"><label>Assign Drivers (optional)</label><select class="form-control" id="g-drivers" multiple style="height:100px"></select><small class="text-gray">Hold Ctrl/Cmd to select multiple</small></div>
</div><div class="modal-footer"><button class="btn btn-outline" onclick="closeM('create-modal')">Cancel</button><button class="btn btn-primary" onclick="createGig()">Create</button></div></div></div>

<!-- Gig Detail Modal -->
<div class="modal-overlay" id="detail-modal"><div class="modal" style="max-width:700px"><div class="modal-header"><h3 id="detail-title">Gig Details</h3><button class="close-btn" onclick="closeM('detail-modal')">&times;</button></div><div class="modal-body" id="detail-body"></div></div></div>

<!-- Assign Driver Modal -->
<div class="modal-overlay" id="assign-modal"><div class="modal"><div class="modal-header"><h3>Assign Driver to Gig</h3><button class="close-btn" onclick="closeM('assign-modal')">&times;</button></div><div class="modal-body">
    <input type="hidden" id="assign-gig-id"/>
    <div class="form-group"><label>Select Driver</label><select class="form-control" id="assign-driver"></select></div>
    <p class="text-sm text-gray">This will assign all orders in this gig to the selected driver and set their status to "assigned".</p>
</div><div class="modal-footer"><button class="btn btn-outline" onclick="closeM('assign-modal')">Cancel</button><button class="btn btn-primary" onclick="confirmAssignDriver()">Assign Driver</button></div></div></div>

@section Scripts {
<script>
if(!ApiService.requireAuth('Admin'))throw'';
let selectedOrders=new Set(),drivers=[],allGigs=[];
document.getElementById('g-date').value=new Date().toISOString().split('T')[0];

// Load drivers
(async()=>{
    const d=await ApiService.get('/admin/drivers');
    drivers=d.drivers;
    const sel=document.getElementById('g-drivers');
    const assignSel=document.getElementById('assign-driver');
    sel.innerHTML=drivers.map(d=>`<option value="${d.id}">${d.user?.firstName||''} ${d.user?.lastName||''}</option>`).join('');
    assignSel.innerHTML=drivers.map(d=>`<option value="${d.id}">${d.user?.firstName||''} ${d.user?.lastName||''}</option>`).join('');
})();

function showTab(tab){
    document.getElementById('tab-active').className='btn '+(tab==='active'?'btn-primary':'btn-outline');
    document.getElementById('tab-completed').className='btn '+(tab==='completed'?'btn-primary':'btn-outline');
    document.getElementById('active-section').style.display=tab==='active'?'block':'none';
    document.getElementById('completed-section').style.display=tab==='completed'?'block':'none';
}
showTab('active');

function closeM(id){document.getElementById(id).classList.remove('active')}
function toggleAll(){const c=document.getElementById('select-all').checked;document.querySelectorAll('.order-cb').forEach(cb=>{cb.checked=c;if(c)selectedOrders.add(parseInt(cb.value));else selectedOrders.delete(parseInt(cb.value))});}

async function loadPending(){
    const d=await ApiService.get('/routes/pending-orders');
    document.getElementById('pending-tbl').innerHTML=d.orders.length?d.orders.map(o=>`<tr><td><input type="checkbox" class="order-cb" value="${o.id}" onchange="toggleOrder(${o.id},this.checked)"/></td><td>${o.orderNumber}</td><td><strong>${o.qrCode||'-'}</strong></td><td>${o.recipientName}</td><td>${o.city}</td><td>${o.deliveryType}</td></tr>`).join(''):'<tr><td colspan="6" class="text-center text-gray">No pending orders</td></tr>';
}
function toggleOrder(id,checked){if(checked)selectedOrders.add(id);else selectedOrders.delete(id);}

async function loadGigs(){
    const d=await ApiService.get('/routes');
    allGigs=d.plans;
    
    // Split into active and completed
    const active=allGigs.filter(g=>g.status!=='completed'&&g.status!=='cancelled');
    const completed=allGigs.filter(g=>g.status==='completed'||g.status==='cancelled');
    
    document.getElementById('gigs-list').innerHTML=active.length?active.map(g=>renderGigCard(g,true)).join(''):'<div class="empty-state"><h3>No active gigs</h3><p>Create a gig and add orders to it.</p></div>';
    document.getElementById('completed-list').innerHTML=completed.length?completed.map(g=>renderGigCard(g,false)).join(''):'<div class="text-center text-gray py-3">No completed gigs yet</div>';
}

function renderGigCard(g,showActions){
    return `<div class="delivery-card" style="margin-bottom:12px">
        <div class="dc-header">
            <div>
                <span class="dc-qr">${g.title}</span> 
                <span class="text-sm text-gray">${g.date}</span>
            </div>
            <div class="d-flex gap-2 items-center">
                ${statusBadge(g.status)}
                ${g.optimizationStatus?`<span class="badge badge-${g.optimizationStatus==='optimized'?'delivered':'new'}">${g.optimizationStatus}</span>`:''}
                <span class="text-sm">${g.orderCount} orders | ${g.driverCount} drivers</span>
            </div>
        </div>
        <div class="dc-actions">
            <button class="btn btn-sm btn-outline" onclick="viewGig(${g.id})">View Details</button>
            ${showActions?`
                <button class="btn btn-sm btn-primary" onclick="addSelectedToGig(${g.id})">Add Orders</button>
                <button class="btn btn-sm btn-warning" onclick="openAssignModal(${g.id})">Assign Driver</button>
                <button class="btn btn-sm btn-info" onclick="optimizeGig(${g.id})">Optimize Route</button>
                ${g.driverCount>0?`<button class="btn btn-sm btn-success" onclick="distributeGig(${g.id})">Distribute</button>`:''}
                <button class="btn btn-sm btn-danger" onclick="deleteGig(${g.id})">Delete</button>
            `:''}
        </div>
    </div>`;
}

async function createGig(){
    const selectedDrivers=[...document.getElementById('g-drivers').selectedOptions].map(o=>parseInt(o.value));
    await ApiService.post('/routes',{
        title:document.getElementById('g-title').value,
        date:document.getElementById('g-date').value,
        driverIds:selectedDrivers
    });
    closeM('create-modal');
    document.getElementById('g-title').value='';
    showAlert('alert-area','success','Gig created!');
    loadGigs();
}

async function addSelectedToGig(gigId){
    if(!selectedOrders.size){showAlert('alert-area','danger','Select orders first');return;}
    await ApiService.post(`/routes/${gigId}/add-orders`,{orderIds:[...selectedOrders]});
    selectedOrders.clear();
    document.getElementById('select-all').checked=false;
    showAlert('alert-area','success','Orders added to gig!');
    loadPending();loadGigs();
}

function openAssignModal(gigId){
    document.getElementById('assign-gig-id').value=gigId;
    document.getElementById('assign-modal').classList.add('active');
}

async function confirmAssignDriver(){
    const gigId=document.getElementById('assign-gig-id').value;
    const driverId=document.getElementById('assign-driver').value;
    if(!driverId){showAlert('alert-area','danger','Select a driver');return;}
    try{
        const r=await ApiService.post(`/routes/${gigId}/assign-driver`,{driverId:parseInt(driverId)});
        closeM('assign-modal');
        showAlert('alert-area','success',r.message);
        loadGigs();loadPending();
    }catch(e){showAlert('alert-area','danger',e.message);}
}

async function optimizeGig(gigId){
    try{
        showAlert('alert-area','info','Optimizing route... (Circuit API)');
        // For now, simulate optimization since Circuit API key may not be set
        await ApiService.put(`/routes/${gigId}`,{optimizationStatus:'optimized'});
        showAlert('alert-area','success','Route optimized! Orders are now in optimal delivery order.');
        loadGigs();
    }catch(e){showAlert('alert-area','warning','Circuit API not configured. Manual optimization only.');}
}

async function distributeGig(gigId){
    try{
        showAlert('alert-area','info','Distributing to drivers...');
        await ApiService.put(`/routes/${gigId}`,{distributed:true,status:'distributed'});
        showAlert('alert-area','success','Gig distributed to drivers!');
        loadGigs();
    }catch(e){showAlert('alert-area','danger',e.message);}
}

async function viewGig(id){
    const d=await ApiService.get(`/routes/${id}`);
    document.getElementById('detail-title').textContent=d.plan.title;
    document.getElementById('detail-body').innerHTML=`
        <div class="d-flex justify-between mb-2">
            <span>Date: <strong>${d.plan.date}</strong></span>
            <div>${statusBadge(d.plan.status)} ${d.plan.optimizationStatus?`<span class="badge badge-info">${d.plan.optimizationStatus}</span>`:''}</div>
        </div>
        <h4>Assigned Drivers</h4>
        ${d.drivers.length?d.drivers.map(dr=>`<span class="badge badge-available">${dr.name}</span> `).join(''):'<span class="text-gray">No drivers assigned yet</span>'}
        <h4 class="mt-2">Stops (${d.orders.length})</h4>
        <table><thead><tr><th>#</th><th>Order</th><th>QR</th><th>Recipient</th><th>Address</th><th>Status</th><th></th></tr></thead>
        <tbody>${d.orders.map((o,i)=>`<tr>
            <td>${i+1}</td>
            <td>${o.orderNumber}</td>
            <td><strong>${o.qrCode||'-'}</strong></td>
            <td>${o.recipientName}</td>
            <td>${o.street}, ${o.city}</td>
            <td>${statusBadge(o.status)}</td>
            <td><button class="btn btn-sm btn-danger" onclick="removeFromGig(${id},${o.id})">Remove</button></td>
        </tr>`).join('')}</tbody></table>
        ${d.orders.length>0?`<div class="mt-2"><a href="https://www.google.com/maps/dir/${d.orders.map(o=>encodeURIComponent(o.street+', '+o.city)).join('/')}" target="_blank" class="btn btn-info btn-sm">${Icons.mapPin} Open Route in Google Maps</a></div>`:''}`;
    document.getElementById('detail-modal').classList.add('active');
}

async function removeFromGig(gigId,orderId){
    await ApiService.delete(`/routes/${gigId}/orders/${orderId}`);
    showAlert('alert-area','success','Order removed');
    viewGig(gigId);loadPending();
}

async function deleteGig(id){
    if(!confirm('Delete this gig?'))return;
    await ApiService.delete(`/routes/${id}`);
    showAlert('alert-area','success','Gig deleted');
    loadGigs();
}

loadPending();loadGigs();
</script>
}
