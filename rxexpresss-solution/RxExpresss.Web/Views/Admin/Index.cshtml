@{ Layout = "_SidebarLayout"; }
<style>
.welcome-bar{background:linear-gradient(135deg,#0f172a,#1e293b);color:white;border-radius:var(--radius);padding:20px 28px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center}
.welcome-bar h2{font-size:20px;margin-bottom:4px}.welcome-bar p{color:#94a3b8;font-size:14px}
.copay-card{background:linear-gradient(135deg,#0d9488,#0f766e);color:white;border-radius:var(--radius);padding:20px;text-align:center}
.copay-card .cv{font-size:28px;font-weight:700}.copay-card .cl{font-size:13px;opacity:.8;margin-top:2px}
.copay-card.pending{background:linear-gradient(135deg,#f59e0b,#d97706)}
.borough-card{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:var(--radius);border:1px solid var(--border);background:white;margin-bottom:8px}
.borough-card .b-code{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;color:white}
.b-Q{background:#3b82f6}.b-B{background:#22c55e}.b-M{background:#f59e0b}.b-S{background:#8b5cf6}.b-X{background:#ef4444}
.order-mini{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);font-size:14px}
.order-mini:last-child{border:none}.order-mini .om-left strong{color:var(--primary)}
</style>

<div class="welcome-bar"><div><h2>Welcome to RX Expresss Admin</h2><p>Manage deliveries across all 5 NYC boroughs</p></div><a href="/Admin/Orders" class="btn btn-primary">View Orders</a></div>
<div class="row mb-3" id="stats-main"></div>
<div class="row mb-3" id="stats-orders"></div>
<div class="row mb-3" id="stats-copay"></div>
<div class="row mb-3">
    <div class="col"><div class="card"><div class="card-header">NYC Borough Breakdown</div><div class="card-body" id="borough-stats"></div></div></div>
    <div class="col-2"><div class="card"><div class="card-header">Recent Orders <a href="/Admin/Orders" class="btn btn-sm btn-outline">View All</a></div><div class="card-body" id="recent-orders"></div></div></div>
</div>

@section Scripts {
<script>
if(!ApiService.requireAuth('Admin'))throw'';
(async()=>{
    const d=await ApiService.get('/admin/dashboard');const s=d.stats;
    document.getElementById('stats-main').innerHTML=`
        <div class="col"><div class="stat-card"><div class="stat-icon teal">${Icons.users}</div><div class="stat-value">${s.total_users}</div><div class="stat-label">Total Users</div></div></div>
        <div class="col"><div class="stat-card"><div class="stat-icon blue">${Icons.pharmacy}</div><div class="stat-value">${s.total_pharmacies}</div><div class="stat-label">Pharmacies</div></div></div>
        <div class="col"><div class="stat-card"><div class="stat-icon green">${Icons.truck}</div><div class="stat-value">${s.active_drivers}</div><div class="stat-label">Active Drivers</div></div></div>
        <div class="col"><div class="stat-card"><div class="stat-icon amber">${Icons.package}</div><div class="stat-value">${s.total_orders}</div><div class="stat-label">Total Orders</div></div></div>`;
    document.getElementById('stats-orders').innerHTML=`
        <div class="col"><div class="stat-card" style="border-left:4px solid #f59e0b"><div class="stat-value">${s.new_orders||0}</div><div class="stat-label">New Orders</div></div></div>
        <div class="col"><div class="stat-card" style="border-left:4px solid #3b82f6"><div class="stat-value">${s.out_for_delivery||0}</div><div class="stat-label">Out for Delivery</div></div></div>
        <div class="col"><div class="stat-card" style="border-left:4px solid #22c55e"><div class="stat-value">${s.delivered_today||0}</div><div class="stat-label">Delivered Today</div></div></div>`;
    document.getElementById('stats-copay').innerHTML=`
        <div class="col"><div class="copay-card pending"><div class="cv">$${(s.copay_to_collect||0).toFixed(2)}</div><div class="cl">Copay to Collect (${s.orders_copay_pending||0} orders)</div></div></div>
        <div class="col"><div class="copay-card"><div class="cv">$${(s.copay_collected||0).toFixed(2)}</div><div class="cl">Copay Collected (${s.orders_copay_collected||0} orders)</div></div></div>`;
    const boroughs=[{code:'Q',name:'Queens'},{code:'B',name:'Brooklyn'},{code:'M',name:'Manhattan'},{code:'S',name:'Staten Island'},{code:'X',name:'Bronx'}];
    const bs=s.borough_stats||{};
    document.getElementById('borough-stats').innerHTML=boroughs.map(b=>`<div class="borough-card"><div class="b-code b-${b.code}">${b.code}</div><div><div style="font-weight:500">${b.name}</div><div class="text-sm text-gray">${bs[b.code]||0} active orders</div></div></div>`).join('');
    const orders=d.recent_orders||[];
    document.getElementById('recent-orders').innerHTML=orders.length?orders.map(o=>`<div class="order-mini"><div class="om-left"><strong>${o.orderNumber}</strong> <span class="text-sm text-gray">${o.qrCode||''}</span><br/><span class="text-sm">${o.recipientName} - ${o.city||''}</span></div><div class="text-right">${statusBadge(o.status)}<br/><span class="text-sm text-gray">${o.copayAmount>0?'$'+o.copayAmount.toFixed(2):''}</span></div></div>`).join(''):'<p class="text-gray">No orders</p>';
})();
</script>
}
