@{ Layout = "_SidebarLayout"; }
@section TopbarRight { 
    <div class="d-flex gap-2">
        <select class="form-control" style="width:160px" id="rf" onchange="load()">
            <option value="">All Roles</option>
            <option value="Admin">Admin</option>
            <option value="Pharmacy">Pharmacy</option>
            <option value="Driver">Driver</option>
            <option value="Patient">Patient</option>
        </select>
        <button class="btn btn-primary" onclick="openAddModal()">+ Add User</button>
    </div>
}
<div class="card"><div class="card-body table-wrap"><table><thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Active</th><th>Joined</th><th>Actions</th></tr></thead><tbody id="tbl"></tbody></table></div></div>

<!-- Add/Edit User Modal -->
<div class="modal-overlay" id="user-modal"><div class="modal"><div class="modal-header"><h3 id="modal-title">Add User</h3><button class="close-btn" onclick="closeModal()">&times;</button></div><div class="modal-body">
    <input type="hidden" id="m-id"/>
    <div class="row"><div class="col"><div class="form-group"><label>First Name</label><input class="form-control" id="m-fn"/></div></div><div class="col"><div class="form-group"><label>Last Name</label><input class="form-control" id="m-ln"/></div></div></div>
    <div class="form-group"><label>Email</label><input type="email" class="form-control" id="m-email"/></div>
    <div class="form-group" id="pw-group"><label>Password</label><input class="form-control" id="m-pw" value="User@123"/></div>
    <div class="form-group"><label>Phone</label><input class="form-control" id="m-phone"/></div>
    <div class="row"><div class="col"><div class="form-group"><label>Role</label><select class="form-control" id="m-role"><option value="Admin">Admin</option><option value="Pharmacy">Pharmacy</option><option value="Driver">Driver</option><option value="Patient">Patient</option></select></div></div><div class="col"><div class="form-group"><label>Status</label><select class="form-control" id="m-active"><option value="true">Active</option><option value="false">Inactive</option></select></div></div></div>
</div><div class="modal-footer"><button class="btn btn-outline" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveUser()">Save</button></div></div></div>

@section Scripts {
<script>
if(!ApiService.requireAuth('Admin'))throw'';

async function load(){
    const r=document.getElementById('rf').value;
    const d=await ApiService.get(r?`/admin/users?role=${r}`:'/admin/users');
    document.getElementById('tbl').innerHTML=d.users.length?d.users.map(u=>`<tr>
        <td><strong>${u.firstName} ${u.lastName}</strong></td>
        <td>${u.email}</td>
        <td>${u.phone||'-'}</td>
        <td><span class="badge badge-available">${u.role}</span></td>
        <td>${u.isActive?'<span class="text-success">Active</span>':'<span class="text-danger">Inactive</span>'}</td>
        <td>${formatDate(u.createdAt)}</td>
        <td>
            <button class="btn btn-sm btn-outline" onclick="openEditModal('${u.id}')">Edit</button>
            <button class="btn btn-sm ${u.isActive?'btn-warning':'btn-success'}" onclick="toggleActive('${u.id}')">${u.isActive?'Deactivate':'Activate'}</button>
            <button class="btn btn-sm btn-danger" onclick="deleteUser('${u.id}')">Delete</button>
        </td>
    </tr>`).join(''):'<tr><td colspan="7" class="text-center text-gray">No users</td></tr>';
}

function closeModal(){document.getElementById('user-modal').classList.remove('active')}

function openAddModal(){
    document.getElementById('modal-title').textContent='Add User';
    document.getElementById('m-id').value='';
    document.getElementById('m-fn').value='';
    document.getElementById('m-ln').value='';
    document.getElementById('m-email').value='';
    document.getElementById('m-pw').value='User@123';
    document.getElementById('m-phone').value='';
    document.getElementById('m-role').value='Patient';
    document.getElementById('m-active').value='true';
    document.getElementById('pw-group').style.display='block';
    document.getElementById('m-email').disabled=false;
    document.getElementById('user-modal').classList.add('active');
}

async function openEditModal(id){
    const u=await ApiService.get(`/admin/users/${id}`);
    document.getElementById('modal-title').textContent='Edit User';
    document.getElementById('m-id').value=id;
    document.getElementById('m-fn').value=u.firstName;
    document.getElementById('m-ln').value=u.lastName;
    document.getElementById('m-email').value=u.email;
    document.getElementById('m-email').disabled=true;
    document.getElementById('m-phone').value=u.phone||'';
    document.getElementById('m-role').value=u.role;
    document.getElementById('m-active').value=u.isActive?'true':'false';
    document.getElementById('pw-group').style.display='none';
    document.getElementById('user-modal').classList.add('active');
}

async function saveUser(){
    const id=document.getElementById('m-id').value;
    try{
        if(id){
            // Update
            await ApiService.put(`/admin/users/${id}`,{
                firstName:document.getElementById('m-fn').value,
                lastName:document.getElementById('m-ln').value,
                phone:document.getElementById('m-phone').value,
                role:document.getElementById('m-role').value,
                isActive:document.getElementById('m-active').value==='true'
            });
            showAlert('alert-area','success','User updated!');
        }else{
            // Create
            await ApiService.post('/admin/users',{
                email:document.getElementById('m-email').value,
                password:document.getElementById('m-pw').value,
                firstName:document.getElementById('m-fn').value,
                lastName:document.getElementById('m-ln').value,
                phone:document.getElementById('m-phone').value,
                role:document.getElementById('m-role').value,
                isActive:document.getElementById('m-active').value==='true'
            });
            showAlert('alert-area','success','User created!');
        }
        closeModal();
        load();
    }catch(e){showAlert('alert-area','danger',e.message);}
}

async function toggleActive(id){
    try{
        const r=await ApiService.put(`/admin/users/${id}/toggle-active`);
        showAlert('alert-area','success',r.message);
        load();
    }catch(e){showAlert('alert-area','danger',e.message);}
}

async function deleteUser(id){
    if(!confirm('Are you sure you want to delete this user?'))return;
    try{
        await ApiService.delete(`/admin/users/${id}`);
        showAlert('alert-area','success','User deleted');
        load();
    }catch(e){showAlert('alert-area','danger',e.message);}
}

load();
</script>
}
