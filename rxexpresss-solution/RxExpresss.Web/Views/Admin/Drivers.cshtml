@{ Layout = "_SidebarLayout"; }
@section TopbarRight { <button class="btn btn-primary" onclick="document.getElementById('add-modal').classList.add('active')">+ Add Driver</button> }
<div class="card"><div class="card-body table-wrap"><table><thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Vehicle</th><th>Status</th><th>Deliveries</th><th>Verified</th></tr></thead><tbody id="tbl"></tbody></table></div></div>
<div class="modal-overlay" id="add-modal"><div class="modal"><div class="modal-header"><h3>Add Driver</h3><button class="close-btn" onclick="document.getElementById('add-modal').classList.remove('active')">&times;</button></div><div class="modal-body">
<div class="row"><div class="col"><div class="form-group"><label>First Name</label><input class="form-control" id="d-fn"/></div></div><div class="col"><div class="form-group"><label>Last Name</label><input class="form-control" id="d-ln"/></div></div></div>
<div class="form-group"><label>Email</label><input type="email" class="form-control" id="d-em"/></div>
<div class="form-group"><label>Password</label><input class="form-control" id="d-pw" value="Driver@123"/></div>
<div class="form-group"><label>Phone</label><input class="form-control" id="d-ph"/></div>
<div class="row"><div class="col"><div class="form-group"><label>Vehicle Type</label><input class="form-control" id="d-vt" value="car"/></div></div><div class="col"><div class="form-group"><label>Vehicle #</label><input class="form-control" id="d-vn"/></div></div></div>
<div class="form-group"><label>License #</label><input class="form-control" id="d-lic"/></div>
</div><div class="modal-footer"><button class="btn btn-outline" onclick="document.getElementById('add-modal').classList.remove('active')">Cancel</button><button class="btn btn-primary" onclick="addDriver()">Create</button></div></div></div>
@section Scripts {
<script>
if(!ApiService.requirePermission('drivers.view'))throw'';
async function load(){const d=await ApiService.get('/admin/drivers');document.getElementById('tbl').innerHTML=d.drivers.length?d.drivers.map(x=>`<tr><td><strong>${x.user?.firstName||''} ${x.user?.lastName||''}</strong></td><td>${x.user?.email||'-'}</td><td>${x.user?.phone||'-'}</td><td>${x.vehicleType} ${x.vehicleNumber}</td><td>${statusBadge(x.status)}</td><td>${x.totalDeliveries}</td><td>${x.isVerified?'<span class="text-success">Yes</span>':'<span class="text-gray">No</span>'}</td></tr>`).join(''):'<tr><td colspan="7" class="text-center text-gray">No drivers</td></tr>';}
async function addDriver(){try{await ApiService.post('/admin/drivers',{firstName:document.getElementById('d-fn').value,lastName:document.getElementById('d-ln').value,email:document.getElementById('d-em').value,password:document.getElementById('d-pw').value,phone:document.getElementById('d-ph').value,vehicleType:document.getElementById('d-vt').value,vehicleNumber:document.getElementById('d-vn').value,licenseNumber:document.getElementById('d-lic').value});document.getElementById('add-modal').classList.remove('active');showAlert('alert-area','success','Driver created!');load();}catch(e){showAlert('alert-area','danger',e.message);}}
load();
</script>
}
