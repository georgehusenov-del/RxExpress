@{ Layout = "_SidebarLayout"; }
@section TopbarRight {
    <div class="d-flex gap-2 items-center">
        <button class="btn btn-primary btn-sm" onclick="load()" title="Refresh Orders" data-testid="refresh-orders-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
            Refresh
        </button>
        <button class="btn btn-primary btn-sm" onclick="openCreateOrderModal()" data-testid="create-order-btn">+ Create Order</button>
        <input type="date" class="form-control" style="width:150px" id="date-filter" onchange="load()"/>
        <select class="form-control" style="width:150px" id="pharmacy-filter" onchange="load()"><option value="">All Pharmacies</option></select>
        <select class="form-control" style="width:150px" id="status-filter" onchange="load()">
            <option value="">All Statuses</option>
            <option value="new">New</option>
            <option value="assigned">Assigned</option>
            <option value="picked_up">Picked Up</option>
            <option value="in_transit">In Transit</option>
            <option value="dispatched">Dispatched</option>
            <option value="out_for_delivery">Out for Delivery</option>
            <option value="delivering_now">Delivering Now</option>
            <option value="delivered">Delivered</option>
            <option value="failed">Failed</option>
            <option value="cancelled">Cancelled</option>
        </select>
        <button class="btn btn-outline btn-sm" onclick="clearFilters()" title="Clear Filters">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
    </div>
}

<div class="card">
    <div class="card-body table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>QR</th>
                    <th>Pharmacy</th>
                    <th>Recipient</th>
                    <th>City</th>
                    <th>Type</th>
                    <th>Copay</th>
                    <th>Status</th>
                    <th>Driver</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tbl"></tbody>
        </table>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="modal">
    <div class="modal">
        <div class="modal-header">
            <h3>Update Order</h3>
            <button class="close-btn" onclick="closeModal('modal')">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="m-id"/>
            <div class="form-group">
                <label>Status</label>
                <select class="form-control" id="m-status">
                    <option value="new">New</option>
                    <option value="assigned">Assigned</option>
                    <option value="picked_up">Picked Up</option>
                    <option value="in_transit">In Transit</option>
                    <option value="dispatched">Dispatched</option>
                    <option value="out_for_delivery">Out for Delivery</option>
                    <option value="delivering_now">Delivering Now</option>
                    <option value="delivered">Delivered</option>
                    <option value="failed">Failed</option>
                    <option value="cancelled">Cancelled</option>
                </select>
            </div>
            <div class="form-group">
                <label>Assign Driver</label>
                <select class="form-control" id="m-driver">
                    <option value="">-- No Change --</option>
                </select>
            </div>
            <div class="form-group">
                <label class="d-flex items-center gap-2">
                    <input type="checkbox" id="m-refrigerated" style="width:18px;height:18px;accent-color:#0288d1"/>
                    <span>❄️ Refrigerated Item (Keep Cold)</span>
                </label>
                <p class="text-sm text-gray mt-1">Mark items that require cold chain handling</p>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('modal')">Cancel</button>
            <button class="btn btn-primary" onclick="doUpdate()">Save</button>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal-overlay" id="detail-modal">
    <div class="modal" style="max-width:600px">
        <div class="modal-header">
            <h3>Order Details</h3>
            <button class="close-btn" onclick="closeModal('detail-modal')">&times;</button>
        </div>
        <div class="modal-body" id="detail-body"></div>
    </div>
</div>

<!-- Create Order Modal -->
<div class="modal-overlay" id="create-order-modal">
    <div class="modal" style="max-width:650px">
        <div class="modal-header">
            <h3>Create Order</h3>
            <button class="close-btn" onclick="closeModal('create-order-modal')">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Pharmacy</label>
                <select class="form-control" id="co-pharmacy" data-testid="co-pharmacy"></select>
            </div>
            <div class="row">
                <div class="col"><div class="form-group"><label>Recipient Name</label><input class="form-control" id="co-name" data-testid="co-name"/></div></div>
                <div class="col"><div class="form-group"><label>Phone</label><input class="form-control" id="co-phone" data-testid="co-phone"/></div></div>
            </div>
            <div class="form-group"><label>Street Address</label><input class="form-control" id="co-street" data-testid="co-street"/></div>
            <div class="row">
                <div class="col"><div class="form-group"><label>Apt/Unit</label><input class="form-control" id="co-apt"/></div></div>
                <div class="col"><div class="form-group"><label>City</label><input class="form-control" id="co-city" value="New York" data-testid="co-city"/></div></div>
            </div>
            <div class="row">
                <div class="col"><div class="form-group"><label>State</label><input class="form-control" id="co-state" value="NY"/></div></div>
                <div class="col"><div class="form-group"><label>Postal Code</label><input class="form-control" id="co-zip" data-testid="co-zip"/></div></div>
            </div>
            <div class="row">
                <div class="col"><div class="form-group"><label>Delivery Type</label>
                    <select class="form-control" id="co-type" data-testid="co-type">
                        <option value="next_day">Next Day</option>
                        <option value="same_day">Same Day</option>
                        <option value="priority">Priority</option>
                        <option value="scheduled">Scheduled</option>
                    </select>
                </div></div>
                <div class="col"><div class="form-group"><label>Copay Amount ($)</label><input type="number" step="0.01" class="form-control" id="co-copay" value="0"/></div></div>
            </div>
            <div class="form-group"><label>Delivery Notes</label><textarea class="form-control" id="co-notes" rows="2"></textarea></div>
            <label class="d-flex items-center gap-2 mt-1"><input type="checkbox" id="co-fridge" style="width:18px;height:18px"/> Refrigerated Item</label>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('create-order-modal')">Cancel</button>
            <button class="btn btn-primary" onclick="submitCreateOrder()" data-testid="submit-create-order">Create Order</button>
        </div>
    </div>
</div>

<!-- Order History / Attempt Timeline Modal -->
<div class="modal-overlay" id="history-modal">
    <div class="modal" style="max-width:700px">
        <div class="modal-header">
            <h3>Order Attempt History</h3>
            <button class="close-btn" onclick="closeModal('history-modal')">&times;</button>
        </div>
        <div class="modal-body" id="history-body" data-testid="history-body"></div>
    </div>
</div>

<!-- Duplicate Order Modal -->
<div class="modal-overlay" id="duplicate-modal">
    <div class="modal" style="max-width:450px">
        <div class="modal-header">
            <h3>Duplicate Order</h3>
            <button class="close-btn" onclick="closeModal('duplicate-modal')">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="dup-order-id"/>
            <p>This order has failed 2+ times. Create a duplicate with a <strong>new QR code</strong>.</p>
            <div class="form-group mt-2">
                <label>Labour Cost ($)</label>
                <input type="number" step="0.01" class="form-control" id="dup-cost" value="10.00" data-testid="dup-cost"/>
                <small class="text-gray">Extra cost added for re-delivery attempt</small>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('duplicate-modal')">Cancel</button>
            <button class="btn btn-primary" onclick="submitDuplicate()" data-testid="submit-duplicate">Duplicate with New QR</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
if(!ApiService.requirePermission('orders.view'))throw'';
let drivers=[], pharmacies=[];
const canCreate = ApiService.hasPermission('orders.create');
const canEdit = ApiService.hasPermission('orders.edit');
const canDuplicate = ApiService.hasPermission('orders.duplicate');

// Hide create button if no permission
if (!canCreate) {
    const createBtn = document.querySelector('[data-testid="create-order-btn"]');
    if (createBtn) createBtn.style.display = 'none';
}

// Load pharmacies for filter
(async()=>{
    try {
        const p = await ApiService.get('/admin/pharmacies');
        pharmacies = p.pharmacies || [];
        const sel = document.getElementById('pharmacy-filter');
        sel.innerHTML = '<option value="">All Pharmacies</option>' + 
            pharmacies.map(ph => `<option value="${ph.id}">${ph.name}</option>`).join('');
    } catch(e) { console.log('Failed to load pharmacies'); }
})();

// Load drivers
(async()=>{
    const d = await ApiService.get('/admin/drivers');
    drivers = d.drivers;
})();

function closeModal(id) { document.getElementById(id).classList.remove('active'); }
function clearFilters() {
    document.getElementById('date-filter').value = '';
    document.getElementById('pharmacy-filter').value = '';
    document.getElementById('status-filter').value = '';
    load();
}

// Status icons with colors - Short labels
const statusIcons = {
    'new': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`, color: '#3b82f6', bg: '#dbeafe', label: 'New' },
    'assigned': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, color: '#8b5cf6', bg: '#ede9fe', label: 'Assigned' },
    'picked_up': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`, color: '#f59e0b', bg: '#fef3c7', label: 'Picked Up' },
    'in_transit': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`, color: '#06b6d4', bg: '#cffafe', label: 'In Transit' },
    'dispatched': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`, color: '#0891b2', bg: '#a5f3fc', label: 'Dispatched' },
    'out_for_delivery': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4l2 2"/></svg>`, color: '#10b981', bg: '#d1fae5', label: 'Out for Delivery' },
    'delivering_now': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`, color: '#059669', bg: '#d1fae5', label: 'Delivering Now' },
    'delivered': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`, color: '#22c55e', bg: '#dcfce7', label: 'Delivered' },
    'failed': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`, color: '#ef4444', bg: '#fee2e2', label: 'Failed' },
    'cancelled': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>`, color: '#6b7280', bg: '#f3f4f6', label: 'Cancelled' }
};

function getStatusDisplay(status) {
    const s = statusIcons[status] || statusIcons['new'];
    return `<span class="status-pill" style="background:${s.bg};color:${s.color};display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:500">${s.icon} ${s.label || status.replace(/_/g, ' ')}</span>`;
}

// Action icons
const actionIcons = {
    view: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    edit: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
    map: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    delete: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>`
};

async function load() {
    try {
        const status = document.getElementById('status-filter').value;
        const pharmacy = document.getElementById('pharmacy-filter').value;
        const date = document.getElementById('date-filter').value;
        
        let url = '/admin/orders?';
        if (status) url += `status=${status}&`;
        if (pharmacy) url += `pharmacyId=${pharmacy}&`;
        
        // Show loading state
        document.getElementById('tbl').innerHTML = '<tr><td colspan="10" class="text-center"><span class="spinner"></span> Loading...</td></tr>';
        
        const d = await ApiService.get(url);
        let orders = d.orders || [];
        
        // Client-side date filter (if API doesn't support it)
        if (date) {
            orders = orders.filter(o => o.createdAt && o.createdAt.startsWith(date));
        }
    
    document.getElementById('tbl').innerHTML = orders.length ? orders.map(o => `
        <tr>
            <td>
                <a href="#" onclick="showDetail(${o.id});return false" style="color:var(--primary);font-weight:600" data-testid="order-link-${o.id}">
                    ${o.orderNumber}
                </a>
            </td>
            <td>
                <strong style="color:${o.isRefrigerated ? '#0288d1' : 'var(--primary)'};${o.isRefrigerated ? 'background:linear-gradient(135deg,#e0f7ff,#b3e5fc);padding:4px 8px;border-radius:6px;' : ''}">${o.qrCode || '-'}</strong>
                ${o.isRefrigerated ? '<span style="color:#0288d1;margin-left:4px" title="Refrigerated">❄️</span>' : ''}
            </td>
            <td>${o.pharmacyName || '-'}</td>
            <td>${o.recipientName}</td>
            <td>${o.city}</td>
            <td><span class="badge badge-info">${o.deliveryType}</span></td>
            <td>${o.copayAmount > 0 ? `<span class="${o.copayCollected ? 'text-success' : 'text-warning'}">$${o.copayAmount.toFixed(2)}</span>` : '<span class="text-gray">$0</span>'}</td>
            <td>${getStatusDisplay(o.status)}</td>
            <td>${o.driverName || '<span class="text-gray">Unassigned</span>'}</td>
            <td>
                <div class="action-btns">
                    <button class="icon-btn" onclick="showDetail(${o.id})" title="View Details" data-testid="view-order-${o.id}">${actionIcons.view}</button>
                    ${canEdit ? `<button class="icon-btn" onclick="openEdit(${o.id},'${o.status}',${o.isRefrigerated || false})" title="Edit" data-testid="edit-order-${o.id}">${actionIcons.edit}</button>` : ''}
                    <a href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(o.street + ', ' + o.city + ', ' + o.state)}" target="_blank" class="icon-btn" title="Open in Maps">${actionIcons.map}</a>
                </div>
            </td>
        </tr>
    `).join('') : '<tr><td colspan="10" class="text-center text-gray">No orders found</td></tr>';
    } catch(err) {
        console.error('Failed to load orders:', err);
        document.getElementById('tbl').innerHTML = '<tr><td colspan="10" class="text-center text-danger">Failed to load orders. Click Refresh to retry.</td></tr>';
    }
}

function openEdit(id, s, isRefrigerated) {
    document.getElementById('m-id').value = id;
    document.getElementById('m-status').value = s;
    document.getElementById('m-refrigerated').checked = isRefrigerated || false;
    const sel = document.getElementById('m-driver');
    sel.innerHTML = '<option value="">-- No Change --</option>' + 
        drivers.map(d => `<option value="${d.id}">${d.user?.firstName || ''} ${d.user?.lastName || ''}</option>`).join('');
    document.getElementById('modal').classList.add('active');
}

async function doUpdate() {
    const id = document.getElementById('m-id').value;
    const newStatus = document.getElementById('m-status').value;
    const did = document.getElementById('m-driver').value;
    const isRefrigerated = document.getElementById('m-refrigerated').checked;
    
    // Prevent setting status to "assigned" without selecting a driver
    if (newStatus === 'assigned' && !did) {
        showAlert('alert-area', 'danger', 'Please select a driver before setting status to Assigned');
        return;
    }
    
    await ApiService.put(`/admin/orders/${id}/status`, { status: newStatus, isRefrigerated: isRefrigerated });
    if (did) await ApiService.put(`/admin/orders/${id}/assign`, { driverId: parseInt(did) });
    
    closeModal('modal');
    showAlert('alert-area', 'success', 'Order updated!');
    load();
}

async function showDetail(id) {
    const o = await ApiService.get(`/orders/${id}`);
    
    // Build POD section if delivered
    let podSection = '';
    if (o.status === 'delivered') {
        podSection = `
            <div class="pod-section mt-3" style="padding-top:16px;border-top:1px solid var(--border)">
                <h4 style="margin-bottom:12px;color:var(--primary)">Proof of Delivery (3 Photos)</h4>
                <div class="d-flex gap-3" style="flex-wrap:wrap">
                    ${o.photoHomeUrl ? `<div>
                        <p class="text-sm text-gray mb-1">📷 1. Home</p>
                        <img src="${o.photoHomeUrl}" alt="Home Photo" style="max-width:150px;max-height:120px;border-radius:8px;border:1px solid var(--border);cursor:pointer" onclick="window.open('${o.photoHomeUrl}','_blank')" data-testid="pod-photo-home"/>
                    </div>` : ''}
                    ${o.photoAddressUrl ? `<div>
                        <p class="text-sm text-gray mb-1">📷 2. Address</p>
                        <img src="${o.photoAddressUrl}" alt="Address Photo" style="max-width:150px;max-height:120px;border-radius:8px;border:1px solid var(--border);cursor:pointer" onclick="window.open('${o.photoAddressUrl}','_blank')" data-testid="pod-photo-address"/>
                    </div>` : ''}
                    ${o.photoPackageUrl ? `<div>
                        <p class="text-sm text-gray mb-1">📷 3. Package</p>
                        <img src="${o.photoPackageUrl}" alt="Package Photo" style="max-width:150px;max-height:120px;border-radius:8px;border:1px solid var(--border);cursor:pointer" onclick="window.open('${o.photoPackageUrl}','_blank')" data-testid="pod-photo-package"/>
                    </div>` : ''}
                    ${!o.photoHomeUrl && !o.photoAddressUrl && !o.photoPackageUrl && o.photoUrl ? `<div>
                        <p class="text-sm text-gray mb-1">Delivery Photo (legacy)</p>
                        <img src="${o.photoUrl}" alt="POD Photo" style="max-width:200px;max-height:150px;border-radius:8px;border:1px solid var(--border);cursor:pointer" onclick="window.open('${o.photoUrl}','_blank')" data-testid="pod-photo"/>
                    </div>` : ''}
                    ${!o.photoHomeUrl && !o.photoAddressUrl && !o.photoPackageUrl && !o.photoUrl ? '<p class="text-gray">No photos available</p>' : ''}
                    ${o.signatureUrl ? `<div>
                        <p class="text-sm text-gray mb-1">Signature</p>
                        <img src="${o.signatureUrl}" alt="Signature" style="max-width:200px;max-height:80px;border-radius:8px;border:1px solid var(--border);background:#fafafa" data-testid="pod-signature"/>
                    </div>` : ''}
                </div>
                ${o.recipientNameSigned ? `<p class="mt-2 text-sm"><strong>Received by:</strong> ${o.recipientNameSigned}</p>` : ''}
                ${o.actualDeliveryTime ? `<p class="text-sm text-gray">Delivered: ${formatDate(o.actualDeliveryTime)}</p>` : ''}
            </div>`;
    }
    
    // Generate QR code image URL - blue for refrigerated
    const qrColor = o.isRefrigerated ? '0288d1' : '000000';
    const qrImageUrl = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=${encodeURIComponent(o.qrCode || o.orderNumber)}&color=${qrColor}`;
    
    document.getElementById('detail-body').innerHTML = `
        <div style="display:grid;grid-template-columns:auto 1fr 1fr;gap:16px">
            <div style="text-align:center;padding:10px;border-right:1px solid var(--border)">
                <img src="${qrImageUrl}" alt="QR Code" style="width:120px;height:120px;border-radius:4px"/>
                <div style="font-weight:700;margin-top:8px;font-size:16px;color:${o.isRefrigerated ? '#0288d1' : 'var(--primary)'}">${o.qrCode || '-'}</div>
                ${o.isRefrigerated ? '<div style="color:#0288d1;font-size:12px;margin-top:4px">❄️ Refrigerated</div>' : ''}
            </div>
            <div>
                <div class="od-row"><span class="text-gray">Order #</span><strong>${o.orderNumber}</strong></div>
                <div class="od-row"><span class="text-gray">Status</span>${getStatusDisplay(o.status)}</div>
                <div class="od-row"><span class="text-gray">Type</span><span class="badge badge-info">${o.deliveryType}</span></div>
                <div class="od-row"><span class="text-gray">Driver</span>${o.driverName || 'Unassigned'}</div>
            </div>
            <div>
                <div class="od-row"><span class="text-gray">Recipient</span>${o.recipientName}</div>
                <div class="od-row"><span class="text-gray">Phone</span>${o.recipientPhone}</div>
                <div class="od-row"><span class="text-gray">Address</span>${o.street}, ${o.city}, ${o.state} ${o.postalCode}</div>
                <div class="od-row"><span class="text-gray">Copay</span>$${(o.copayAmount || 0).toFixed(2)} ${o.copayCollected ? '<span class="text-success">(Collected)</span>' : ''}</div>
                <div class="od-row"><span class="text-gray">Fee</span>$${(o.deliveryFee || 0).toFixed(2)}</div>
            </div>
        </div>
        ${podSection}
        <div class="mt-2 d-flex gap-2">
            <button class="btn btn-sm btn-primary" onclick="printQrCode('${o.qrCode || ''}', '${o.orderNumber}', '${o.recipientName}', '${o.street}, ${o.city}', ${o.isRefrigerated || false})">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                Print QR Label
            </button>
            <a href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(o.street + ', ' + o.city + ', ' + o.state)}" target="_blank" class="btn btn-sm btn-outline">
                ${actionIcons.map} Open in Google Maps
            </a>
            <button class="btn btn-sm btn-outline" onclick="closeModal('detail-modal');showHistory(${o.id})" data-testid="history-btn-${o.id}">
                <i class="fas fa-history"></i> Attempt History
            </button>
            ${o.status === 'failed' && canDuplicate && (o.failedAttempts || 0) >= 2 ? `<button class="btn btn-sm btn-warning" onclick="closeModal('detail-modal');openDuplicateModal(${o.id})" data-testid="duplicate-btn-${o.id}">Duplicate Order</button>` : ''}
        </div>`;
    document.getElementById('detail-modal').classList.add('active');
}

// ========== Create Order ==========
function openCreateOrderModal() {
    const sel = document.getElementById('co-pharmacy');
    sel.innerHTML = pharmacies.map(p => `<option value="${p.id}">${p.name}</option>`).join('');
    document.getElementById('co-name').value = '';
    document.getElementById('co-phone').value = '';
    document.getElementById('co-street').value = '';
    document.getElementById('co-apt').value = '';
    document.getElementById('co-city').value = 'New York';
    document.getElementById('co-state').value = 'NY';
    document.getElementById('co-zip').value = '';
    document.getElementById('co-type').value = 'next_day';
    document.getElementById('co-copay').value = '0';
    document.getElementById('co-notes').value = '';
    document.getElementById('co-fridge').checked = false;
    document.getElementById('create-order-modal').classList.add('active');
}

async function submitCreateOrder() {
    try {
        const r = await ApiService.post('/admin/orders/create', {
            pharmacyId: parseInt(document.getElementById('co-pharmacy').value),
            recipientName: document.getElementById('co-name').value,
            recipientPhone: document.getElementById('co-phone').value,
            street: document.getElementById('co-street').value,
            aptUnit: document.getElementById('co-apt').value,
            city: document.getElementById('co-city').value,
            state: document.getElementById('co-state').value,
            postalCode: document.getElementById('co-zip').value,
            deliveryType: document.getElementById('co-type').value,
            copayAmount: parseFloat(document.getElementById('co-copay').value) || 0,
            deliveryNotes: document.getElementById('co-notes').value,
            isRefrigerated: document.getElementById('co-fridge').checked
        });
        closeModal('create-order-modal');
        toast(`Order ${r.orderNumber} created (QR: ${r.qrCode})`, 'success');
        load();
    } catch(e) { toast(e.message, 'danger'); }
}

// ========== Order History ==========
async function showHistory(orderId) {
    try {
        const h = await ApiService.get(`/admin/orders/${orderId}/history`);
        
        let html = `
            <div class="history-summary" data-testid="history-summary">
                <div class="hs-item"><strong>Total Attempts:</strong> ${h.totalAttempts}</div>
                <div class="hs-item"><strong>Total Failed:</strong> <span style="color:#ef4444">${h.totalFailed}</span></div>
                <div class="hs-item"><strong>Total Labour Cost:</strong> $${h.totalLabourCost.toFixed(2)}</div>
            </div>
            <h4 class="mt-2 mb-1">Order Chain</h4>`;
        
        html += h.orders.map(o => `
            <div class="history-order ${o.id === orderId ? 'history-current' : ''}" data-testid="history-order-${o.id}">
                <div class="ho-header">
                    <strong>Attempt #${o.attemptNumber}: ${o.orderNumber}</strong>
                    <span class="badge" style="background:${o.qrCode ? 'var(--primary)' : '#94a3b8'};color:#fff">${o.qrCode}</span>
                </div>
                <div class="ho-details">
                    ${getStatusDisplay(o.status)}
                    ${o.driverName ? `<span class="text-gray">Driver: ${o.driverName}</span>` : ''}
                    ${o.labourCost > 0 ? `<span style="color:#f59e0b">Labour: $${o.labourCost.toFixed(2)}</span>` : ''}
                    <span class="text-gray">${formatDate(o.createdAt)}</span>
                </div>
            </div>
        `).join('');
        
        if (h.logs.length) {
            html += '<h4 class="mt-2 mb-1">Attempt Log</h4>';
            html += h.logs.map(l => `
                <div class="history-log">
                    <div class="hl-dot" style="background:${l.status === 'failed' ? '#ef4444' : '#22c55e'}"></div>
                    <div>
                        <strong>${l.status === 'failed' ? 'Failed' : 'Delivered'}</strong> — Attempt #${l.attemptNumber}
                        ${l.driverName ? `<span class="text-gray">by ${l.driverName}</span>` : ''}
                        ${l.failureReason ? `<div class="text-sm" style="color:#ef4444">${l.failureReason}</div>` : ''}
                        ${l.notes ? `<div class="text-sm text-gray">${l.notes}</div>` : ''}
                        <small class="text-gray">${formatDate(l.timestamp)}</small>
                    </div>
                </div>
            `).join('');
        }
        
        document.getElementById('history-body').innerHTML = html;
        document.getElementById('history-modal').classList.add('active');
    } catch(e) { toast('Failed to load history', 'danger'); }
}

// ========== Duplicate Order ==========
function openDuplicateModal(orderId) {
    document.getElementById('dup-order-id').value = orderId;
    document.getElementById('dup-cost').value = '10.00';
    document.getElementById('duplicate-modal').classList.add('active');
}

async function submitDuplicate() {
    const orderId = document.getElementById('dup-order-id').value;
    const cost = parseFloat(document.getElementById('dup-cost').value) || 10;
    try {
        const r = await ApiService.post(`/admin/orders/${orderId}/duplicate`, { labourCost: cost });
        closeModal('duplicate-modal');
        toast(`Order duplicated! New: ${r.newOrderNumber} (QR: ${r.newQrCode}), Labour: $${r.labourCost}`, 'success');
        load();
    } catch(e) { toast(e.message, 'danger'); }
}

load();
</script>

