@{ Layout = "_SidebarLayout"; }
@section TopbarRight {
    <div class="d-flex gap-2 items-center">
        <input type="date" class="form-control" style="width:150px" id="date-filter" onchange="load()"/>
        <select class="form-control" style="width:150px" id="pharmacy-filter" onchange="load()"><option value="">All Pharmacies</option></select>
        <select class="form-control" style="width:150px" id="status-filter" onchange="load()">
            <option value="">All Statuses</option>
            <option value="new">New</option>
            <option value="assigned">Assigned</option>
            <option value="picked_up">Picked Up</option>
            <option value="in_transit">In Transit</option>
            <option value="out_for_delivery">Out for Delivery</option>
            <option value="delivered">Delivered</option>
            <option value="failed">Failed</option>
        </select>
        <button class="btn btn-outline btn-sm" onclick="clearFilters()" title="Clear Filters">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
    </div>
}

<div class="card">
    <div class="card-body table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>QR</th>
                    <th>Pharmacy</th>
                    <th>Recipient</th>
                    <th>City</th>
                    <th>Type</th>
                    <th>Copay</th>
                    <th>Status</th>
                    <th>Driver</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tbl"></tbody>
        </table>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="modal">
    <div class="modal">
        <div class="modal-header">
            <h3>Update Order</h3>
            <button class="close-btn" onclick="closeModal('modal')">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="m-id"/>
            <div class="form-group">
                <label>Status</label>
                <select class="form-control" id="m-status">
                    <option value="new">New</option>
                    <option value="assigned">Assigned</option>
                    <option value="picked_up">Picked Up</option>
                    <option value="in_transit">In Transit</option>
                    <option value="out_for_delivery">Out for Delivery</option>
                    <option value="delivered">Delivered</option>
                    <option value="failed">Failed</option>
                    <option value="cancelled">Cancelled</option>
                </select>
            </div>
            <div class="form-group">
                <label>Assign Driver</label>
                <select class="form-control" id="m-driver">
                    <option value="">-- No Change --</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('modal')">Cancel</button>
            <button class="btn btn-primary" onclick="doUpdate()">Save</button>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal-overlay" id="detail-modal">
    <div class="modal" style="max-width:600px">
        <div class="modal-header">
            <h3>Order Details</h3>
            <button class="close-btn" onclick="closeModal('detail-modal')">&times;</button>
        </div>
        <div class="modal-body" id="detail-body"></div>
    </div>
</div>

@section Scripts {
<script>
if(!ApiService.requireAuth('Admin'))throw'';
let drivers=[], pharmacies=[];

// Load pharmacies for filter
(async()=>{
    try {
        const p = await ApiService.get('/admin/pharmacies');
        pharmacies = p.pharmacies || [];
        const sel = document.getElementById('pharmacy-filter');
        sel.innerHTML = '<option value="">All Pharmacies</option>' + 
            pharmacies.map(ph => `<option value="${ph.id}">${ph.name}</option>`).join('');
    } catch(e) { console.log('Failed to load pharmacies'); }
})();

// Load drivers
(async()=>{
    const d = await ApiService.get('/admin/drivers');
    drivers = d.drivers;
})();

function closeModal(id) { document.getElementById(id).classList.remove('active'); }
function clearFilters() {
    document.getElementById('date-filter').value = '';
    document.getElementById('pharmacy-filter').value = '';
    document.getElementById('status-filter').value = '';
    load();
}

// Status icons with colors
const statusIcons = {
    'new': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`, color: '#3b82f6', bg: '#dbeafe' },
    'assigned': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, color: '#8b5cf6', bg: '#ede9fe' },
    'picked_up': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>`, color: '#f59e0b', bg: '#fef3c7' },
    'in_transit': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`, color: '#06b6d4', bg: '#cffafe' },
    'out_for_delivery': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4l2 2"/></svg>`, color: '#10b981', bg: '#d1fae5' },
    'delivered': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`, color: '#22c55e', bg: '#dcfce7' },
    'failed': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`, color: '#ef4444', bg: '#fee2e2' },
    'cancelled': { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>`, color: '#6b7280', bg: '#f3f4f6' }
};

function getStatusDisplay(status) {
    const s = statusIcons[status] || statusIcons['new'];
    return `<span class="status-pill" style="background:${s.bg};color:${s.color};display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:500">${s.icon} ${status.replace(/_/g, ' ')}</span>`;
}

// Action icons
const actionIcons = {
    view: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    edit: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
    map: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    delete: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>`
};

async function load() {
    const status = document.getElementById('status-filter').value;
    const pharmacy = document.getElementById('pharmacy-filter').value;
    const date = document.getElementById('date-filter').value;
    
    let url = '/admin/orders?';
    if (status) url += `status=${status}&`;
    if (pharmacy) url += `pharmacyId=${pharmacy}&`;
    
    const d = await ApiService.get(url);
    let orders = d.orders || [];
    
    // Client-side date filter (if API doesn't support it)
    if (date) {
        orders = orders.filter(o => o.createdAt && o.createdAt.startsWith(date));
    }
    
    document.getElementById('tbl').innerHTML = orders.length ? orders.map(o => `
        <tr>
            <td>
                <a href="#" onclick="showDetail(${o.id});return false" style="color:var(--primary);font-weight:600" data-testid="order-link-${o.id}">
                    ${o.orderNumber}
                </a>
            </td>
            <td><strong style="color:var(--primary)">${o.qrCode || '-'}</strong></td>
            <td>${o.pharmacyName || '-'}</td>
            <td>${o.recipientName}</td>
            <td>${o.city}</td>
            <td><span class="badge badge-info">${o.deliveryType}</span></td>
            <td>${o.copayAmount > 0 ? `<span class="${o.copayCollected ? 'text-success' : 'text-warning'}">$${o.copayAmount.toFixed(2)}</span>` : '<span class="text-gray">$0</span>'}</td>
            <td>${getStatusDisplay(o.status)}</td>
            <td>${o.driverName || '<span class="text-gray">Unassigned</span>'}</td>
            <td>
                <div class="action-btns">
                    <button class="icon-btn" onclick="showDetail(${o.id})" title="View Details" data-testid="view-order-${o.id}">${actionIcons.view}</button>
                    <button class="icon-btn" onclick="openEdit(${o.id},'${o.status}')" title="Edit" data-testid="edit-order-${o.id}">${actionIcons.edit}</button>
                    <a href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(o.street + ', ' + o.city + ', ' + o.state)}" target="_blank" class="icon-btn" title="Open in Maps">${actionIcons.map}</a>
                </div>
            </td>
        </tr>
    `).join('') : '<tr><td colspan="10" class="text-center text-gray">No orders found</td></tr>';
}

function openEdit(id, s) {
    document.getElementById('m-id').value = id;
    document.getElementById('m-status').value = s;
    const sel = document.getElementById('m-driver');
    sel.innerHTML = '<option value="">-- No Change --</option>' + 
        drivers.map(d => `<option value="${d.id}">${d.user?.firstName || ''} ${d.user?.lastName || ''}</option>`).join('');
    document.getElementById('modal').classList.add('active');
}

async function doUpdate() {
    const id = document.getElementById('m-id').value;
    const newStatus = document.getElementById('m-status').value;
    const did = document.getElementById('m-driver').value;
    
    // Prevent setting status to "assigned" without selecting a driver
    if (newStatus === 'assigned' && !did) {
        showAlert('alert-area', 'danger', 'Please select a driver before setting status to Assigned');
        return;
    }
    
    await ApiService.put(`/admin/orders/${id}/status`, { status: newStatus });
    if (did) await ApiService.put(`/admin/orders/${id}/assign`, { driverId: parseInt(did) });
    
    closeModal('modal');
    showAlert('alert-area', 'success', 'Order updated!');
    load();
}

async function showDetail(id) {
    const o = await ApiService.get(`/orders/${id}`);
    
    // Build POD section if delivered
    let podSection = '';
    if (o.status === 'delivered') {
        podSection = `
            <div class="pod-section mt-3" style="padding-top:16px;border-top:1px solid var(--border)">
                <h4 style="margin-bottom:12px;color:var(--primary)">📷 Proof of Delivery</h4>
                <div class="d-flex gap-3" style="flex-wrap:wrap">
                    ${o.photoUrl ? `<div>
                        <p class="text-sm text-gray mb-1">Delivery Photo</p>
                        <img src="${o.photoUrl}" alt="POD Photo" style="max-width:200px;max-height:150px;border-radius:8px;border:1px solid var(--border);cursor:pointer" onclick="window.open('${o.photoUrl}','_blank')" data-testid="pod-photo"/>
                    </div>` : '<p class="text-gray">No photo available</p>'}
                    ${o.signatureUrl ? `<div>
                        <p class="text-sm text-gray mb-1">Signature</p>
                        <img src="${o.signatureUrl}" alt="Signature" style="max-width:200px;max-height:80px;border-radius:8px;border:1px solid var(--border);background:#fafafa" data-testid="pod-signature"/>
                    </div>` : ''}
                </div>
                ${o.recipientNameSigned ? `<p class="mt-2 text-sm"><strong>Received by:</strong> ${o.recipientNameSigned}</p>` : ''}
                ${o.actualDeliveryTime ? `<p class="text-sm text-gray">Delivered: ${formatDate(o.actualDeliveryTime)}</p>` : ''}
            </div>`;
    }
    
    document.getElementById('detail-body').innerHTML = `
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div>
                <div class="od-row"><span class="text-gray">Order #</span><strong>${o.orderNumber}</strong></div>
                <div class="od-row"><span class="text-gray">QR Code</span><strong style="color:var(--primary)">${o.qrCode || '-'}</strong></div>
                <div class="od-row"><span class="text-gray">Status</span>${getStatusDisplay(o.status)}</div>
                <div class="od-row"><span class="text-gray">Type</span><span class="badge badge-info">${o.deliveryType}</span></div>
                <div class="od-row"><span class="text-gray">Driver</span>${o.driverName || 'Unassigned'}</div>
            </div>
            <div>
                <div class="od-row"><span class="text-gray">Recipient</span>${o.recipientName}</div>
                <div class="od-row"><span class="text-gray">Phone</span>${o.recipientPhone}</div>
                <div class="od-row"><span class="text-gray">Address</span>${o.street}, ${o.city}, ${o.state} ${o.postalCode}</div>
                <div class="od-row"><span class="text-gray">Copay</span>$${(o.copayAmount || 0).toFixed(2)} ${o.copayCollected ? '<span class="text-success">(Collected)</span>' : ''}</div>
                <div class="od-row"><span class="text-gray">Fee</span>$${(o.deliveryFee || 0).toFixed(2)}</div>
            </div>
        </div>
        ${podSection}
        <div class="mt-2 d-flex gap-2">
            <button class="btn btn-sm btn-primary" onclick="printQrCode('${o.qrCode || ''}', '${o.orderNumber}', '${o.recipientName}', '${o.street}, ${o.city}')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                Print QR Label
            </button>
            <a href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(o.street + ', ' + o.city + ', ' + o.state)}" target="_blank" class="btn btn-sm btn-outline">
                ${actionIcons.map} Open in Google Maps
            </a>
        </div>`;
    document.getElementById('detail-modal').classList.add('active');
}

// Print QR Code Label Function
function printQrCode(qrCode, orderNumber, recipientName, address) {
    const printWindow = window.open('', '_blank', 'width=400,height=500');
    printWindow.document.write(`
        <!DOCTYPE html>
        <html>
        <head>
            <title>Print QR - ${qrCode}</title>
            <style>
                * { margin: 0; padding: 0; box-sizing: border-box; }
                body { font-family: Arial, sans-serif; padding: 20px; }
                .label { 
                    border: 2px solid #000; 
                    padding: 15px; 
                    width: 300px; 
                    text-align: center;
                }
                .qr-code { 
                    font-size: 48px; 
                    font-weight: bold; 
                    letter-spacing: 2px;
                    padding: 20px 0;
                    border-bottom: 1px solid #ccc;
                    margin-bottom: 10px;
                }
                .order-num { 
                    font-size: 14px; 
                    color: #666; 
                    margin-bottom: 8px;
                }
                .recipient { 
                    font-size: 16px; 
                    font-weight: bold;
                    margin-bottom: 4px;
                }
                .address { 
                    font-size: 12px; 
                    color: #444;
                }
                .logo {
                    font-size: 18px;
                    font-weight: bold;
                    color: #0d9488;
                    margin-bottom: 10px;
                }
                .barcode {
                    margin-top: 15px;
                    font-family: 'Libre Barcode 39', monospace;
                    font-size: 36px;
                }
                @media print {
                    body { padding: 0; }
                    .no-print { display: none; }
                }
            </style>
        </head>
        <body>
            <div class="label">
                <div class="logo">RX Expresss</div>
                <div class="qr-code">${qrCode}</div>
                <div class="order-num">${orderNumber}</div>
                <div class="recipient">${recipientName}</div>
                <div class="address">${address}</div>
                <div class="barcode">*${qrCode}*</div>
            </div>
            <div class="no-print" style="margin-top:20px;text-align:center">
                <button onclick="window.print()" style="padding:10px 20px;font-size:16px;cursor:pointer">Print Label</button>
            </div>
            <script>
                // Auto-print after small delay
                setTimeout(() => window.print(), 500);
            </script>
        </body>
        </html>
    `);
    printWindow.document.close();
}

load();
</script>

<style>
.action-btns { display: flex; gap: 4px; }
.icon-btn { 
    background: transparent; 
    border: 1px solid var(--border); 
    border-radius: 6px; 
    padding: 6px; 
    cursor: pointer; 
    color: var(--text-secondary);
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
}
.icon-btn:hover { 
    background: var(--primary); 
    color: white; 
    border-color: var(--primary);
}
.od-row { 
    display: flex; 
    justify-content: space-between; 
    padding: 6px 0; 
    border-bottom: 1px solid var(--border); 
    font-size: 14px; 
}
.od-row:last-child { border: none; }
.status-pill { text-transform: capitalize; }
</style>
}
