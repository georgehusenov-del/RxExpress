@{ Layout = "_SidebarLayout"; }
@section TopbarRight {
    <select class="form-control" style="width:170px" id="sf" onchange="load()"><option value="">All Statuses</option><option value="new">New</option><option value="assigned">Assigned</option><option value="picked_up">Picked Up</option><option value="in_transit">In Transit</option><option value="out_for_delivery">Out for Delivery</option><option value="delivered">Delivered</option><option value="failed">Failed</option></select>
}
<div class="card"><div class="card-body table-wrap"><table><thead><tr><th>Order #</th><th>QR</th><th>Pharmacy</th><th>Recipient</th><th>City</th><th>Type</th><th>Copay</th><th>Status</th><th>Driver</th><th>Actions</th></tr></thead><tbody id="tbl"></tbody></table></div></div>

<div class="modal-overlay" id="modal"><div class="modal"><div class="modal-header"><h3>Update Order</h3><button class="close-btn" onclick="document.getElementById('modal').classList.remove('active')">&times;</button></div><div class="modal-body"><input type="hidden" id="m-id"/>
<div class="form-group"><label>Status</label><select class="form-control" id="m-status"><option value="new">New</option><option value="assigned">Assigned</option><option value="picked_up">Picked Up</option><option value="in_transit">In Transit</option><option value="out_for_delivery">Out for Delivery</option><option value="delivered">Delivered</option><option value="failed">Failed</option><option value="cancelled">Cancelled</option></select></div>
<div class="form-group"><label>Assign Driver</label><select class="form-control" id="m-driver"><option value="">-- No Change --</option></select></div>
</div><div class="modal-footer"><button class="btn btn-outline" onclick="document.getElementById('modal').classList.remove('active')">Cancel</button><button class="btn btn-primary" onclick="doUpdate()">Save</button></div></div></div>

<div class="modal-overlay" id="detail-modal"><div class="modal" style="max-width:600px"><div class="modal-header"><h3>Order Details</h3><button class="close-btn" onclick="document.getElementById('detail-modal').classList.remove('active')">&times;</button></div><div class="modal-body" id="detail-body"></div></div></div>

@section Scripts {
<script>
if(!ApiService.requireAuth('Admin'))throw'';
let drivers=[];
(async()=>{const d=await ApiService.get('/admin/drivers');drivers=d.drivers;})();
async function load(){const s=document.getElementById('sf').value;const d=await ApiService.get(s?`/admin/orders?status=${s}`:'/admin/orders');document.getElementById('tbl').innerHTML=d.orders.length?d.orders.map(o=>`<tr><td><a href="#" onclick="showDetail(${o.id});return false" style="color:var(--primary);font-weight:600">${o.orderNumber}</a></td><td><strong>${o.qrCode||'-'}</strong></td><td>${o.pharmacyName||'-'}</td><td>${o.recipientName}</td><td>${o.city}</td><td>${o.deliveryType}</td><td>${o.copayAmount>0?`<span class="${o.copayCollected?'text-success':'text-warning'}">$${o.copayAmount.toFixed(2)}</span>`:'$0'}</td><td>${statusBadge(o.status)}</td><td>${o.driverName||'<span class="text-gray">-</span>'}</td><td><button class="btn btn-sm btn-outline" onclick="openEdit(${o.id},'${o.status}')">Edit</button></td></tr>`).join(''):'<tr><td colspan="10" class="text-center text-gray">No orders</td></tr>';}
function openEdit(id,s){document.getElementById('m-id').value=id;document.getElementById('m-status').value=s;const sel=document.getElementById('m-driver');sel.innerHTML='<option value="">-- No Change --</option>'+drivers.map(d=>`<option value="${d.id}">${d.user?.firstName||''} ${d.user?.lastName||''}</option>`).join('');document.getElementById('modal').classList.add('active');}
async function doUpdate(){const id=document.getElementById('m-id').value;await ApiService.put(`/admin/orders/${id}/status`,{status:document.getElementById('m-status').value});const did=document.getElementById('m-driver').value;if(did)await ApiService.put(`/admin/orders/${id}/assign`,{driverId:parseInt(did)});document.getElementById('modal').classList.remove('active');showAlert('alert-area','success','Updated!');load();}
async function showDetail(id){const o=await ApiService.get(`/orders/${id}`);document.getElementById('detail-body').innerHTML=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px"><div><div class="od-row"><span class="text-gray">Order #</span><strong>${o.orderNumber}</strong></div><div class="od-row"><span class="text-gray">QR Code</span><strong style="color:var(--primary)">${o.qrCode||'-'}</strong></div><div class="od-row"><span class="text-gray">Status</span>${statusBadge(o.status)}</div><div class="od-row"><span class="text-gray">Type</span>${o.deliveryType}</div><div class="od-row"><span class="text-gray">Driver</span>${o.driverName||'Unassigned'}</div></div><div><div class="od-row"><span class="text-gray">Recipient</span>${o.recipientName}</div><div class="od-row"><span class="text-gray">Phone</span>${o.recipientPhone}</div><div class="od-row"><span class="text-gray">Address</span>${o.street}, ${o.city}, ${o.state} ${o.postalCode}</div><div class="od-row"><span class="text-gray">Copay</span>$${(o.copayAmount||0).toFixed(2)}</div><div class="od-row"><span class="text-gray">Fee</span>$${(o.deliveryFee||0).toFixed(2)}</div></div></div><div class="mt-2"><a href="https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(o.street+', '+o.city+', '+o.state)}" target="_blank" class="btn btn-sm btn-outline">${Icons.mapPin} Open in Google Maps</a></div>`;document.getElementById('detail-modal').classList.add('active');}
load();
</script>
<style>.od-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);font-size:14px}.od-row:last-child{border:none}</style>
}
