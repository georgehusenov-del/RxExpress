@{ ViewData["Title"] = "Login"; Layout = "_Layout"; }
<div class="auth-wrapper">
    <div class="auth-card">
        <h1>RX Expresss</h1>
        <p>Pharmacy Delivery Service</p>
        <div id="alert-area"></div>
        <form id="login-form">
            <div class="form-group"><label>Email</label><input type="email" class="form-control" id="email" placeholder="Enter your email" required /></div>
            <div class="form-group"><label>Password</label><input type="password" class="form-control" id="password" placeholder="Enter your password" required /></div>
            <button type="submit" class="btn btn-primary btn-lg w-full" id="login-btn">Sign In</button>
        </form>
        <div class="mt-2 text-center">
            <a href="/Home/ForgotPassword" style="color:var(--primary);font-size:14px">Forgot Password?</a>
        </div>
        <!-- Test accounts commented out for production
        <div class="mt-3 text-center text-sm text-gray">
            <strong>Test Accounts:</strong><br/>
            Admin: admin@rxexpresss.com / Admin@123<br/>
            Pharmacy: pharmacy@test.com / Pharmacy@123<br/>
            Driver: driver@test.com / Driver@123
        </div>
        -->
    </div>
</div>
@section Scripts {
<script>
    if (ApiService.isLoggedIn()) {
        const u = ApiService.getUser();
        if (u) window.location.replace('/' + u.role + '/Index');
    }
    document.getElementById('login-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('login-btn');
        btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Signing in...';
        try {
            const d = await ApiService.login(
                document.getElementById('email').value,
                document.getElementById('password').value
            );
            if (d && d.user) {
                window.location.replace('/' + d.user.role + '/Index');
            } else {
                showAlert('alert-area', 'danger', 'Login failed - no response');
                btn.disabled = false; btn.textContent = 'Sign In';
            }
        } catch (err) {
            showAlert('alert-area', 'danger', err.message);
            btn.disabled = false; btn.textContent = 'Sign In';
        }
    });
</script>
}
