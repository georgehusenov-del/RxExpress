@{ ViewData["Title"] = "Forgot Password"; Layout = "_Layout"; }
<div class="auth-wrapper">
    <div class="auth-card">
        <h1>Reset Password</h1>
        <p>Enter your email to receive a password reset link</p>
        <div id="alert-area"></div>
        <form id="forgot-form">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" class="form-control" id="email" placeholder="Enter your email" required />
            </div>
            <button type="submit" class="btn btn-primary btn-lg w-full" id="reset-btn">Send Reset Link</button>
        </form>
        <div class="mt-3 text-center">
            <a href="/Home/Login" style="color:var(--primary)">Back to Login</a>
        </div>
    </div>
</div>
@section Scripts {
<script>
    document.getElementById('forgot-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('reset-btn');
        const email = document.getElementById('email').value;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span> Sending...';
        try {
            const resp = await fetch(`${API_BASE_URL}/auth/forgot-password`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            });
            if (resp.ok) {
                showAlert('alert-area', 'success', 'If an account exists with this email, you will receive a password reset link.');
                document.getElementById('forgot-form').reset();
            } else {
                const data = await resp.json();
                showAlert('alert-area', 'danger', data.detail || 'Failed to send reset link');
            }
        } catch (err) {
            showAlert('alert-area', 'danger', 'An error occurred. Please try again.');
        }
        btn.disabled = false;
        btn.textContent = 'Send Reset Link';
    });
</script>
}
