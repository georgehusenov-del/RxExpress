// QR Scanner - Updated for action-based scanning with geo-lock
function openScanModal(orderId, expectedQr, action){
    // Check geo-lock for office scan
    if (!canPerformScan(action)) {
        return; // Geo-lock prevented scan
    }
    
    document.getElementById('scan-order-id').value=orderId;
    document.getElementById('scan-expected-qr').value=expectedQr;
    document.getElementById('scan-action').value=action;
    document.getElementById('manual-qr').value='';
    currentScanAction = action;
    
    // Update modal title based on action
    const titles = {
        'verify': 'Verify Package QR',
        'pickup': 'Scan to Pick Up Package',
        'intransit': 'Scan at Office (In Transit)',
        'outfordelivery': 'Scan to Dispatch (Out for Delivery)',
        'delivering': 'Scan - Start Delivering'
    };
    document.getElementById('scan-modal-title').textContent = titles[action] || 'Scan Package QR';
    
    const instructions = {
        'verify': 'Point camera at package QR code to verify',
        'pickup': 'Scan the package QR to mark as PICKED UP',
        'intransit': 'Scan at office to mark as IN TRANSIT',
        'outfordelivery': 'Scan before leaving to mark as OUT FOR DELIVERY',
        'delivering': 'Scan when starting delivery to this location'
    };
    document.getElementById('scan-instruction').textContent = instructions[action] || 'Point camera at package QR code';
    
    document.getElementById('scan-modal').classList.add('active');
    startQrScanner();
}

async function closeScanModal(){
    await stopQrScanner();
    document.getElementById('scan-modal').classList.remove('active');
}

async function startQrScanner(){
    try{
        html5QrCode=new Html5Qrcode("qr-reader");
        await html5QrCode.start(
            {facingMode:"environment"},
            {fps:10,qrbox:{width:200,height:200}},
            onQrScanned,
            ()=>{}
        );
        scannerRunning=true;
    }catch(e){
        console.log('Camera not available');
        scannerRunning=false;
    }
}

async function stopQrScanner(){
    if(html5QrCode && scannerRunning){
        try{
            await html5QrCode.stop();
        }catch(e){
            // Ignore errors
        }
        scannerRunning=false;
    }
    html5QrCode=null;
}

function onQrScanned(code){
    verifyQrCode(code);
}

async function verifyManualQr(){
    const code=document.getElementById('manual-qr').value.trim();
    if(code) await verifyQrCode(code);
}

async function verifyQrCode(code){
    const orderId=parseInt(document.getElementById('scan-order-id').value);
    const expected=document.getElementById('scan-expected-qr').value;
    const action=document.getElementById('scan-action').value;
    
    if(code.toUpperCase()===expected.toUpperCase()){
        scannedSet.add(orderId);
        await closeScanModal();
        
        // Map action to status
        const statusMap = {
            'pickup': 'picked_up',
            'intransit': 'in_transit',
            'outfordelivery': 'out_for_delivery',
            'delivering': 'delivering_now'
        };
        
        if(action === 'verify') {
            showAlert('alert-area','success','✓ Package verified!');
        } else if(statusMap[action]) {
            try {
                await ApiService.put(`/driver-portal/deliveries/${orderId}/status?status=${statusMap[action]}`);
                const statusLabels = {
                    'picked_up': 'Picked Up',
                    'in_transit': 'In Transit',
                    'out_for_delivery': 'Out for Delivery',
                    'delivering_now': 'Delivering Now'
                };
                showAlert('alert-area','success',`✓ Status updated to: ${statusLabels[statusMap[action]]}`);
            } catch(e) {
                showAlert('alert-area','danger', e.message || 'Failed to update status');
            }
        }
        
        loadDeliveries();
    }else{
        showAlert('alert-area','danger',`QR mismatch! Expected: ${expected}, Got: ${code}`);
    }
}

