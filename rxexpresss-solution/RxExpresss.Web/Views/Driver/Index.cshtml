@{ Layout = "_SidebarLayout"; }
<style>
.stop-badge{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:50%;background:var(--primary);color:white;font-weight:700;font-size:13px;margin-right:8px}
.nav-btn{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:var(--radius);border:1px solid var(--border);background:white;cursor:pointer;font-size:12px;color:var(--info);text-decoration:none}
.nav-btn:hover{background:#dbeafe}
.scan-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;background:#dcfce7;color:#15803d}
#qr-reader{width:100%;max-width:300px;margin:0 auto}
.history-section{margin-top:24px;padding-top:16px;border-top:1px solid var(--border)}
.photo-preview{max-width:200px;max-height:150px;border-radius:8px;margin-top:8px;display:none}
.signature-pad{border:1px solid var(--border);border-radius:8px;background:#fafafa;touch-action:none}
.pod-required{color:#ef4444;font-size:12px;margin-top:4px}
.status-info{background:#f8fafc;border-radius:8px;padding:12px;margin-bottom:16px;font-size:13px}
.status-legend{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}
.status-legend span{padding:2px 8px;border-radius:4px;font-size:11px}

/* Camera capture styles */
.photo-container{display:flex;flex-direction:column;align-items:center;gap:8px;padding:12px;border:2px dashed var(--border);border-radius:8px;background:#f8fafc}
.photo-preview-large{max-width:100%;max-height:200px;border-radius:8px;border:2px solid var(--primary)}
.btn-camera{padding:16px 24px;font-size:16px;background:linear-gradient(135deg,#22c55e,#16a34a);color:white;border:none;border-radius:8px;cursor:pointer;display:flex;align-items:center;gap:8px}
.btn-camera:hover{background:linear-gradient(135deg,#16a34a,#15803d)}
.retake-btn{margin-top:8px}
.photo-captured .photo-container{border-color:#22c55e;background:#f0fdf4}

/* Refrigerated items - Blue QR code styling is inline */
</style>

@section TopbarRight {
<div class="d-flex gap-2 items-center">
    <span class="text-sm text-gray">Status:</span>
    <div class="toggle-group">
        <button class="toggle-btn" id="t-on" onclick="setStatus('available')">Online</button>
        <button class="toggle-btn" id="t-off" onclick="setStatus('offline')">Offline</button>
    </div>
</div>
}

<div id="route-nav" class="mb-2" style="display:none">
    <a href="#" id="full-route-btn" class="btn btn-info" target="_blank">@Html.Raw(SvgIcons.Route) Navigate Full Route</a>
</div>

<!-- Tabs -->
<div class="mb-2">
    <button class="btn btn-primary" id="tab-active" onclick="showTab('active')">Active Deliveries</button>
    <button class="btn btn-outline" id="tab-history" onclick="showTab('history')" style="margin-left:8px">Delivery History</button>
</div>

<div id="active-section">
    <div id="deliveries"><div class="text-center mt-3"><span class="spinner"></span> Loading...</div></div>
</div>

<div id="history-section" style="display:none">
    <div id="history-list"><div class="text-center mt-3"><span class="spinner"></span> Loading...</div></div>
</div>

<!-- QR Scanner Modal -->
<div class="modal-overlay" id="scan-modal">
    <div class="modal">
        <div class="modal-header">
            <h3 id="scan-modal-title">Scan Package QR</h3>
            <button class="close-btn" onclick="closeScanModal()">&times;</button>
        </div>
        <div class="modal-body text-center">
            <input type="hidden" id="scan-order-id"/>
            <input type="hidden" id="scan-expected-qr"/>
            <input type="hidden" id="scan-action"/>
            <div id="qr-reader"></div>
            <p class="text-sm text-gray mt-2" id="scan-instruction">Point camera at package QR code</p>
            <div class="mt-2">
                <input type="text" class="form-control" id="manual-qr" placeholder="Or enter QR manually..." style="max-width:200px;display:inline-block" data-testid="manual-qr-input"/>
                <button class="btn btn-primary btn-sm" onclick="verifyManualQr()" data-testid="verify-qr-btn">Verify</button>
            </div>
        </div>
    </div>
</div>

<!-- POD Modal - 3 Required Photos via Direct Camera Capture -->
<div class="modal-overlay" id="pod-modal">
    <div class="modal" style="max-width:500px;max-height:90vh;overflow-y:auto">
        <div class="modal-header">
            <h3>Complete Delivery (POD)</h3>
            <button class="close-btn" onclick="closePodModal()">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="pod-order-id"/>
            
            <div class="form-group">
                <label>Recipient Name (who received it)</label>
                <input type="text" class="form-control" id="pod-name" placeholder="Enter recipient name" data-testid="pod-name-input"/>
            </div>
            
            <!-- Photo 1: Home -->
            <div class="form-group photo-capture-group">
                <label>📸 Photo 1: Picture of Home <span style="color:#ef4444">*</span></label>
                <div id="photo-container-home" class="photo-container">
                    <img id="preview-home" class="photo-preview-large" style="display:none" alt="Home Preview"/>
                    <button type="button" class="btn btn-camera" onclick="openCamera('home')" id="btn-capture-home" data-testid="capture-home-btn">
                        📷 Open Camera & Take Photo
                    </button>
                    <button type="button" class="btn btn-sm btn-outline retake-btn" onclick="openCamera('home')" id="btn-retake-home" style="display:none">
                        🔄 Retake Photo
                    </button>
                </div>
                <p class="text-sm text-gray">Take a clear photo of the customer's home/building</p>
                <input type="hidden" id="pod-photo-home-data"/>
            </div>
            
            <!-- Photo 2: Address -->
            <div class="form-group photo-capture-group">
                <label>📸 Photo 2: Picture of Address <span style="color:#ef4444">*</span></label>
                <div id="photo-container-address" class="photo-container">
                    <img id="preview-address" class="photo-preview-large" style="display:none" alt="Address Preview"/>
                    <button type="button" class="btn btn-camera" onclick="openCamera('address')" id="btn-capture-address" data-testid="capture-address-btn">
                        📷 Open Camera & Take Photo
                    </button>
                    <button type="button" class="btn btn-sm btn-outline retake-btn" onclick="openCamera('address')" id="btn-retake-address" style="display:none">
                        🔄 Retake Photo
                    </button>
                </div>
                <p class="text-sm text-gray">Capture visible house number or address sign</p>
                <input type="hidden" id="pod-photo-address-data"/>
            </div>
            
            <!-- Photo 3: Package at Door -->
            <div class="form-group photo-capture-group">
                <label>📸 Photo 3: Package at Door <span style="color:#ef4444">*</span></label>
                <div id="photo-container-package" class="photo-container">
                    <img id="preview-package" class="photo-preview-large" style="display:none" alt="Package Preview"/>
                    <button type="button" class="btn btn-camera" onclick="openCamera('package')" id="btn-capture-package" data-testid="capture-package-btn">
                        📷 Open Camera & Take Photo
                    </button>
                    <button type="button" class="btn btn-sm btn-outline retake-btn" onclick="openCamera('package')" id="btn-retake-package" style="display:none">
                        🔄 Retake Photo
                    </button>
                </div>
                <p class="text-sm text-gray">Show package placed at the door/entrance</p>
                <input type="hidden" id="pod-photo-package-data"/>
            </div>
            
            <div class="form-group" id="signature-group">
                <label>Signature (optional)</label>
                <canvas id="signature-pad" class="signature-pad" width="300" height="100"></canvas>
                <div class="d-flex gap-2 mt-1">
                    <button class="btn btn-sm btn-outline" onclick="clearSignature()">Clear</button>
                </div>
                <p class="text-sm text-gray">Signature is optional if delivery instructions say to leave at door</p>
            </div>
            
            <div class="form-group">
                <label>Notes (optional)</label>
                <textarea class="form-control" id="pod-notes" placeholder="Any delivery notes..." rows="2" data-testid="pod-notes-input"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closePodModal()">Cancel</button>
            <button class="btn btn-success" onclick="submitPod()" data-testid="submit-pod-btn">Complete Delivery</button>
        </div>
    </div>
</div>

<!-- Camera Capture Modal (Full Screen) -->
<div class="modal-overlay" id="camera-modal" style="background:black;z-index:2000">
    <div style="width:100%;height:100%;display:flex;flex-direction:column">
        <div style="padding:10px;background:rgba(0,0,0,0.8);color:white;display:flex;justify-content:space-between;align-items:center">
            <span id="camera-title">📷 Take Photo</span>
            <button onclick="closeCamera()" style="background:none;border:none;color:white;font-size:24px;cursor:pointer">&times;</button>
        </div>
        <div style="flex:1;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative">
            <video id="camera-video" autoplay playsinline style="max-width:100%;max-height:100%;object-fit:contain"></video>
            <canvas id="camera-canvas" style="display:none"></canvas>
        </div>
        <div style="padding:20px;background:rgba(0,0,0,0.8);display:flex;justify-content:center;gap:20px">
            <button onclick="capturePhoto()" class="btn" style="width:70px;height:70px;border-radius:50%;background:white;border:4px solid #22c55e;font-size:24px" data-testid="shutter-btn">
                📸
            </button>
        </div>
    </div>
</div>

<!-- Failed Delivery Modal -->
<div class="modal-overlay" id="failed-modal">
    <div class="modal" style="max-width:400px">
        <div class="modal-header">
            <h3>Mark Delivery as Failed</h3>
            <button class="close-btn" onclick="closeFailedModal()">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="failed-order-id"/>
            <div class="form-group">
                <label>Reason</label>
                <select class="form-control" id="failed-reason">
                    <option value="patient_not_home">Patient Not Home</option>
                    <option value="wrong_address">Wrong Address</option>
                    <option value="refused_delivery">Refused Delivery</option>
                    <option value="other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label>Notes</label>
                <textarea class="form-control" id="failed-notes" placeholder="Additional details..." rows="2"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeFailedModal()">Cancel</button>
            <button class="btn btn-danger" onclick="submitFailed()">Mark as Failed</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://unpkg.com/html5-qrcode"></script>
<script>
if(!ApiService.requireAuth('Driver'))throw'';

let myStatus='offline';
const scannedSet=new Set();
let html5QrCode=null;
let scannerRunning=false;
let signaturePad=null;
let isDrawing=false;
let currentScanAction='verify'; // verify, pickup, intransit, outfordelivery, delivering

function showTab(tab){
    document.getElementById('tab-active').className='btn '+(tab==='active'?'btn-primary':'btn-outline');
    document.getElementById('tab-history').className='btn '+(tab==='history'?'btn-primary':'btn-outline');
    document.getElementById('active-section').style.display=tab==='active'?'block':'none';
    document.getElementById('history-section').style.display=tab==='history'?'block':'none';
    if(tab==='history')loadHistory();
}

async function loadProfile(){
    try{
        const p=await ApiService.get('/driver-portal/profile');
        myStatus=p.status;
        updateToggle();
    }catch{}
}

function updateToggle(){
    document.getElementById('t-on').className='toggle-btn'+(myStatus==='available'?' active':'');
    document.getElementById('t-off').className='toggle-btn'+(myStatus==='offline'?' off':'');
}

async function setStatus(s){
    await ApiService.put(`/driver-portal/status?status=${s}`);
    myStatus=s;
    updateToggle();
}

function mapsUrl(addr){return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(addr)}`;}

// Status display helpers
function getNextAction(status, isScanned) {
    switch(status) {
        case 'assigned':
            // Driver assigned for pickup from pharmacy
            return { action: 'pickup', label: 'Scan to Pick Up', icon: '📦', color: 'btn-warning' };
        case 'picked_up':
            // Going to office
            return { action: 'intransit', label: 'Scan at Office', icon: '🏢', color: 'btn-info' };
        case 'in_transit':
            // At office - driver shouldn't see this (will be unassigned)
            return null;
        case 'dispatched':
            // Driver assigned for delivery - leaving office
            return { action: 'outfordelivery', label: 'Scan - Out for Delivery', icon: '🚗', color: 'btn-primary' };
        case 'out_for_delivery':
            // On route to stop
            return { action: 'delivering', label: 'Scan - At Location', icon: '📍', color: 'btn-success' };
        case 'delivering_now':
            // At location - show POD buttons
            return { action: 'pod', label: 'Complete Delivery', icon: '✅', color: 'btn-success' };
        default:
            return null;
    }
}

async function loadDeliveries(){
    try{
        const d=await ApiService.get('/driver-portal/deliveries');
        const el=document.getElementById('deliveries');
        
        if(!d.deliveries.length){
            el.innerHTML='<div class="empty-state"><h3>No Active Deliveries</h3><p>No deliveries assigned right now. Check back later!</p></div>';
            document.getElementById('route-nav').style.display='none';
            return;
        }
        
        const addrs=d.deliveries.map(o=>`${o.street}, ${o.city}, ${o.state} ${o.postalCode}`);
        if(addrs.length>1){
            document.getElementById('full-route-btn').href=`https://www.google.com/maps/dir/${addrs.map(a=>encodeURIComponent(a)).join('/')}`;
            document.getElementById('route-nav').style.display='block';
        }
        
        el.innerHTML=d.deliveries.map((o,i)=>{
            const addr=`${o.street}, ${o.city}, ${o.state} ${o.postalCode}`;
            const isS=scannedSet.has(o.id);
            const nextAction = getNextAction(o.status, isS);
            const isRefrigerated = o.isRefrigerated || false;
            
            return `<div class="delivery-card">
                <div class="dc-header">
                    <div>
                        <span class="stop-badge">${i+1}</span>
                        <span class="dc-qr" style="${isRefrigerated ? 'color:#0288d1;background:linear-gradient(135deg,#e0f7ff,#b3e5fc);padding:4px 8px;border-radius:6px;' : ''}">${o.qrCode||o.orderNumber}</span>
                        ${isRefrigerated ? '<span style="color:#0288d1;margin-left:4px;font-size:14px" title="Refrigerated - Keep Cold!">❄️</span>' : ''}
                    </div>
                    <div class="d-flex gap-2 items-center">
                        ${isS?'<span class="scan-badge">✓ Verified</span>':''}
                        ${statusBadge(o.status)}
                        <a href="${mapsUrl(addr)}" target="_blank" class="nav-btn">${Icons.mapPin} Navigate</a>
                    </div>
                </div>
                <div class="dc-details">
                    <div><strong>To:</strong> ${o.recipientName}</div>
                    <div><strong>Phone:</strong> <a href="tel:${o.recipientPhone}">${o.recipientPhone}</a></div>
                    <div><strong>Address:</strong> ${addr}</div>
                    ${o.copayAmount>0?`<div><strong>Copay:</strong> $${o.copayAmount.toFixed(2)} ${o.copayCollected?'<span class="text-success">(Collected)</span>':'<span class="text-warning">(Pending)</span>'}</div>`:''}
                    ${o.deliveryInstructions?`<div class="text-info"><strong>Instructions:</strong> ${o.deliveryInstructions}</div>`:''}
                </div>
                ${o.deliveryNotes?`<div class="mt-1 text-sm text-gray">Notes: ${o.deliveryNotes}</div>`:''}
                <div class="dc-actions">
                    ${nextAction && nextAction.action !== 'pod' ? `<button class="btn btn-sm ${nextAction.color}" onclick="openScanModal(${o.id},'${o.qrCode||''}','${nextAction.action}')">${nextAction.icon} ${nextAction.label}</button>` : ''}
                    ${o.status==='delivering_now' ? `<button class="btn btn-sm btn-success" onclick="openPodModal(${o.id})">✅ Complete Delivery (POD)</button>` : ''}
                    ${o.status==='delivering_now' ? `<button class="btn btn-sm btn-danger" onclick="openFailedModal(${o.id})">❌ Failed Delivery</button>` : ''}
                    ${o.copayAmount>0&&!o.copayCollected?`<button class="btn btn-sm btn-outline" onclick="copay(${o.id})">💵 Collect $${o.copayAmount.toFixed(2)}</button>`:''}
                </div>
            </div>`;
        }).join('');
    }catch(e){showAlert('alert-area','danger',e.message);}
}

async function loadHistory(){
    try{
        const d=await ApiService.get('/driver-portal/history');
        document.getElementById('history-list').innerHTML=d.deliveries.length?d.deliveries.map(o=>`
            <div class="delivery-card" style="opacity:0.95">
                <div class="dc-header">
                    <div>
                        <span class="dc-qr" style="${o.isRefrigerated ? 'color:#0288d1;background:linear-gradient(135deg,#e0f7ff,#b3e5fc);padding:4px 8px;border-radius:6px;' : ''}">${o.qrCode||o.orderNumber}</span>
                        ${o.isRefrigerated ? '<span style="color:#0288d1;margin-left:4px" title="Refrigerated">❄️</span>' : ''}
                    </div>
                    <div class="d-flex gap-2 items-center">
                        ${statusBadge(o.status)}
                        ${o.photoUrl?`<span class="scan-badge">📷 POD</span>`:''}
                        ${o.signatureUrl?`<span class="scan-badge">✍️ Signed</span>`:''}
                    </div>
                </div>
                <div class="dc-details">
                    <div><strong>To:</strong> ${o.recipientName}</div>
                    <div><strong>Phone:</strong> ${o.recipientPhone || '-'}</div>
                    <div><strong>Address:</strong> ${o.street}, ${o.city}, ${o.state || ''}</div>
                    <div><strong>Delivered:</strong> ${o.actualDeliveryTime?formatDate(o.actualDeliveryTime):(o.updatedAt?formatDate(o.updatedAt):'-')}</div>
                    ${o.recipientNameSigned?`<div><strong>Received by:</strong> ${o.recipientNameSigned}</div>`:''}
                    ${o.copayAmount>0?`<div><strong>Copay:</strong> $${o.copayAmount.toFixed(2)} ${o.copayCollected?'<span class="text-success">(Collected)</span>':''}</div>`:''}
                </div>
                ${o.deliveryNotes?`<div class="mt-1 text-sm text-gray">Notes: ${o.deliveryNotes}</div>`:''}
            </div>
        `).join(''):'<div class="text-center text-gray py-3">No delivery history yet</div>';
    }catch{
        document.getElementById('history-list').innerHTML='<div class="text-center text-gray py-3">Unable to load history</div>';
    }
}

// QR Scanner - Updated for action-based scanning
function openScanModal(orderId, expectedQr, action){
    document.getElementById('scan-order-id').value=orderId;
    document.getElementById('scan-expected-qr').value=expectedQr;
    document.getElementById('scan-action').value=action;
    document.getElementById('manual-qr').value='';
    currentScanAction = action;
    
    // Update modal title based on action
    const titles = {
        'verify': 'Verify Package QR',
        'pickup': 'Scan to Pick Up Package',
        'intransit': 'Scan at Office (In Transit)',
        'outfordelivery': 'Scan to Dispatch (Out for Delivery)',
        'delivering': 'Scan - Start Delivering'
    };
    document.getElementById('scan-modal-title').textContent = titles[action] || 'Scan Package QR';
    
    const instructions = {
        'verify': 'Point camera at package QR code to verify',
        'pickup': 'Scan the package QR to mark as PICKED UP',
        'intransit': 'Scan at office to mark as IN TRANSIT',
        'outfordelivery': 'Scan before leaving to mark as OUT FOR DELIVERY',
        'delivering': 'Scan when starting delivery to this location'
    };
    document.getElementById('scan-instruction').textContent = instructions[action] || 'Point camera at package QR code';
    
    document.getElementById('scan-modal').classList.add('active');
    startQrScanner();
}

async function closeScanModal(){
    await stopQrScanner();
    document.getElementById('scan-modal').classList.remove('active');
}

async function startQrScanner(){
    try{
        html5QrCode=new Html5Qrcode("qr-reader");
        await html5QrCode.start(
            {facingMode:"environment"},
            {fps:10,qrbox:{width:200,height:200}},
            onQrScanned,
            ()=>{}
        );
        scannerRunning=true;
    }catch(e){
        console.log('Camera not available');
        scannerRunning=false;
    }
}

async function stopQrScanner(){
    if(html5QrCode && scannerRunning){
        try{
            await html5QrCode.stop();
        }catch(e){
            // Ignore errors
        }
        scannerRunning=false;
    }
    html5QrCode=null;
}

function onQrScanned(code){
    verifyQrCode(code);
}

async function verifyManualQr(){
    const code=document.getElementById('manual-qr').value.trim();
    if(code) await verifyQrCode(code);
}

async function verifyQrCode(code){
    const orderId=parseInt(document.getElementById('scan-order-id').value);
    const expected=document.getElementById('scan-expected-qr').value;
    const action=document.getElementById('scan-action').value;
    
    if(code.toUpperCase()===expected.toUpperCase()){
        scannedSet.add(orderId);
        await closeScanModal();
        
        // Map action to status
        const statusMap = {
            'pickup': 'picked_up',
            'intransit': 'in_transit',
            'outfordelivery': 'out_for_delivery',
            'delivering': 'delivering_now'
        };
        
        if(action === 'verify') {
            showAlert('alert-area','success','✓ Package verified!');
        } else if(statusMap[action]) {
            try {
                await ApiService.put(`/driver-portal/deliveries/${orderId}/status?status=${statusMap[action]}`);
                const statusLabels = {
                    'picked_up': 'Picked Up',
                    'in_transit': 'In Transit',
                    'out_for_delivery': 'Out for Delivery',
                    'delivering_now': 'Delivering Now'
                };
                showAlert('alert-area','success',`✓ Status updated to: ${statusLabels[statusMap[action]]}`);
            } catch(e) {
                showAlert('alert-area','danger', e.message || 'Failed to update status');
            }
        }
        
        loadDeliveries();
    }else{
        showAlert('alert-area','danger',`QR mismatch! Expected: ${expected}, Got: ${code}`);
    }
}

// POD with 3 mandatory camera photos
let currentPhotoType = null;
let cameraStream = null;

function openPodModal(orderId){
    document.getElementById('pod-order-id').value=orderId;
    document.getElementById('pod-name').value='';
    document.getElementById('pod-notes').value='';
    
    // Reset all 3 photos
    ['home', 'address', 'package'].forEach(type => {
        document.getElementById(`preview-${type}`).style.display='none';
        document.getElementById(`preview-${type}`).src='';
        document.getElementById(`pod-photo-${type}-data`).value='';
        document.getElementById(`btn-capture-${type}`).style.display='flex';
        document.getElementById(`btn-retake-${type}`).style.display='none';
        document.getElementById(`photo-container-${type}`).parentElement.classList.remove('photo-captured');
    });
    
    document.getElementById('pod-modal').classList.add('active');
    initSignaturePad();
}

function closePodModal(){
    document.getElementById('pod-modal').classList.remove('active');
    closeCamera();
}

// Camera Functions
async function openCamera(photoType) {
    currentPhotoType = photoType;
    
    const titles = {
        'home': '📸 Photo 1: Picture of Home',
        'address': '📸 Photo 2: Picture of Address', 
        'package': '📸 Photo 3: Package at Door'
    };
    document.getElementById('camera-title').textContent = titles[photoType] || '📷 Take Photo';
    
    try {
        // Request camera access - rear camera preferred
        cameraStream = await navigator.mediaDevices.getUserMedia({
            video: { 
                facingMode: { ideal: 'environment' }, // Use rear camera
                width: { ideal: 1280 },
                height: { ideal: 720 }
            },
            audio: false
        });
        
        const video = document.getElementById('camera-video');
        video.srcObject = cameraStream;
        await video.play();
        
        document.getElementById('camera-modal').classList.add('active');
    } catch (err) {
        console.error('Camera error:', err);
        showAlert('alert-area', 'danger', 'Camera access denied or not available. Please allow camera permissions.');
    }
}

function closeCamera() {
    if (cameraStream) {
        cameraStream.getTracks().forEach(track => track.stop());
        cameraStream = null;
    }
    document.getElementById('camera-modal').classList.remove('active');
    currentPhotoType = null;
}

function capturePhoto() {
    const video = document.getElementById('camera-video');
    const canvas = document.getElementById('camera-canvas');
    const ctx = canvas.getContext('2d');
    
    // Set canvas size to video size
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    
    // Draw video frame to canvas
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
    
    // Get image as base64
    const imageData = canvas.toDataURL('image/jpeg', 0.8);
    
    // Store the captured image
    document.getElementById(`pod-photo-${currentPhotoType}-data`).value = imageData;
    
    // Show preview
    const preview = document.getElementById(`preview-${currentPhotoType}`);
    preview.src = imageData;
    preview.style.display = 'block';
    
    // Hide capture button, show retake button
    document.getElementById(`btn-capture-${currentPhotoType}`).style.display = 'none';
    document.getElementById(`btn-retake-${currentPhotoType}`).style.display = 'inline-block';
    
    // Mark as captured
    document.getElementById(`photo-container-${currentPhotoType}`).parentElement.classList.add('photo-captured');
    
    // Close camera
    closeCamera();
    
    showAlert('alert-area', 'success', `✓ Photo captured!`);
}

