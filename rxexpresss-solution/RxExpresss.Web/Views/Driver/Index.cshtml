// Signature Pad
function initSignaturePad(){
    const canvas=document.getElementById('signature-pad');
    const ctx=canvas.getContext('2d');
    ctx.fillStyle='#fafafa';
    ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.strokeStyle='#000';
    ctx.lineWidth=2;
    ctx.lineCap='round';
    
    let lastX,lastY;
    
    function getPos(e){
        const rect=canvas.getBoundingClientRect();
        const x=(e.touches?e.touches[0].clientX:e.clientX)-rect.left;
        const y=(e.touches?e.touches[0].clientY:e.clientY)-rect.top;
        return {x,y};
    }
    
    function startDraw(e){
        e.preventDefault();
        isDrawing=true;
        const pos=getPos(e);
        lastX=pos.x;
        lastY=pos.y;
    }
    
    function draw(e){
        if(!isDrawing)return;
        e.preventDefault();
        const pos=getPos(e);
        ctx.beginPath();
        ctx.moveTo(lastX,lastY);
        ctx.lineTo(pos.x,pos.y);
        ctx.stroke();
        lastX=pos.x;
        lastY=pos.y;
    }
    
    function stopDraw(){
        isDrawing=false;
    }
    
    canvas.addEventListener('mousedown',startDraw);
    canvas.addEventListener('mousemove',draw);
    canvas.addEventListener('mouseup',stopDraw);
    canvas.addEventListener('mouseleave',stopDraw);
    canvas.addEventListener('touchstart',startDraw);
    canvas.addEventListener('touchmove',draw);
    canvas.addEventListener('touchend',stopDraw);
}

function clearSignature(){
    const canvas=document.getElementById('signature-pad');
    const ctx=canvas.getContext('2d');
    ctx.fillStyle='#fafafa';
    ctx.fillRect(0,0,canvas.width,canvas.height);
}

function getSignatureData(){
    const canvas=document.getElementById('signature-pad');
    // Check if signature has any strokes
    const ctx=canvas.getContext('2d');
    const pixelData=ctx.getImageData(0,0,canvas.width,canvas.height).data;
    let hasSignature=false;
    for(let i=0;i<pixelData.length;i+=4){
        // Check if pixel is not the background color (#fafafa = 250,250,250)
        if(pixelData[i]<240 || pixelData[i+1]<240 || pixelData[i+2]<240){
            hasSignature=true;
            break;
        }
    }
    return hasSignature ? canvas.toDataURL('image/png') : null;
}

async function submitPod(){
    const orderId=document.getElementById('pod-order-id').value;
    const name=document.getElementById('pod-name').value;
    const notes=document.getElementById('pod-notes').value;
    
    // Get captured photos from hidden inputs
    const photoHomeBase64 = document.getElementById('pod-photo-home-data').value;
    const photoAddressBase64 = document.getElementById('pod-photo-address-data').value;
    const photoPackageBase64 = document.getElementById('pod-photo-package-data').value;
    
    // Validate all 3 photos - MANDATORY
    if(!photoHomeBase64){
        showAlert('alert-area','danger','Photo of HOME is required! Please use the camera to take a photo.');
        return;
    }
    if(!photoAddressBase64){
        showAlert('alert-area','danger','Photo of ADDRESS is required! Please use the camera to take a photo.');
        return;
    }
    if(!photoPackageBase64){
        showAlert('alert-area','danger','Photo of PACKAGE at door is required! Please use the camera to take a photo.');
        return;
    }
    
    try {
        showAlert('alert-area','info','Uploading 3 photos... Please wait.');
        
        // Get signature (optional)
        const signatureBase64 = getSignatureData();
        
        const payload = {
            recipientName: name || null,
            photoHomeBase64: photoHomeBase64,
            photoAddressBase64: photoAddressBase64,
            photoPackageBase64: photoPackageBase64,
            signatureBase64: signatureBase64,
            notes: notes || null
        };
        
        const result = await ApiService.post(`/driver-portal/deliveries/${orderId}/pod`, payload);
        
        scannedSet.delete(parseInt(orderId));
        closePodModal();
        showAlert('alert-area','success','✓ Delivery completed! All 3 POD photos uploaded.');
        loadDeliveries();
    } catch(e) {
        showAlert('alert-area','danger', e.message || 'Failed to submit POD');
    }
}

async function copay(id){
    if(!confirm('Confirm copay collected from customer?'))return;
    await ApiService.post(`/driver-portal/deliveries/${id}/collect-copay`);
    showAlert('alert-area','success','Copay collected!');
    loadDeliveries();
}

